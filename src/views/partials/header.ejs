<header class="header shadow-sm">
    <nav class="navbar custom-navbar">
        <div class="container d-flex align-items-center justify-content-between flex-wrap">

            <!-- Logo + brand -->
            <a href="/" class="navbar-brand d-flex align-items-center fw-bold text-white mb-2 mb-lg-0">
                <div class="logo-inner me-2">
                    <img src="/images/logo.png" alt="logo" class="logo-img" />
                </div>
                Tourist Management
            </a>

            <!-- MENU + USER -->
            <div class="d-flex align-items-center flex-wrap gap-3">

                <!-- Left menu -->
                <ul class="navbar-nav flex-row flex-wrap mb-0">
                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" href="/">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" href="/phong">Phòng</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" href="/khachhang/don-dat-phong">Đơn đặt phòng</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" href="/lienhe">Liên hệ</a>
                    </li>

                    <% if (session.user && session.user.PhanQuyen === 'Admin') { %>
                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" href="/admin/dashboard">Quản trị</a>
                    </li>
                    <% } %>
                </ul>

                <!-- Right user actions -->
                <div class="d-flex align-items-center gap-2 ms-3">

                    <% if (!session.user) { %>

                        <a href="/khachhang/dangky" class="btn btn-outline-light rounded-pill px-3">
                            Đăng ký
                        </a>
                        <a href="/khachhang/dangnhap" class="btn btn-light rounded-pill px-3">
                            Đăng nhập
                        </a>

                    <% } else { %>

                        <% if (session.user.PhanQuyen === 'NhaCungCap') { %>
                            <a href="/nhacungcap/" class="btn btn-light rounded-pill px-3">
                                Quản lý chỗ ở
                            </a>

                        <% } else if (session.user.PhanQuyen === 'Admin') { %>
                            <a href="/admin/dashboard" class="btn btn-warning rounded-pill px-3">
                                Trang quản trị
                            </a>

                        <% } else { %>
                            <a href="/khachhang/thongtintaikhoan"
                               class="user-pill rounded-pill px-3 text-white">
                                👤 <%= session.user.TaiKhoan %>
                            </a>
                        <% } %>

                        <a href="/khachhang/dangxuat" class="btn btn-danger rounded-pill px-3">
                            Đăng xuất
                        </a>

                    <% } %>

                </div>
            </div>
        </div>
    </nav>
</header>
