<body>
  <header class="header">
      <nav class="navbar">
          <a href="/" class="logo">
              <div class="logo">
                  <img src="../../public/images/logo.png" alt="logo" sizes="" srcset="">
              </div>
              Tourist Management
          </a>
          <ul class="nav-links">
              <li><a href="/">Trang chủ</a></li>
              <li><a href="/phong">Phòng</a></li>
              <li><a href="khachhang/don-dat-phong">Đơn đặt phòng</a></li>
              <li><a href="/lienhe">Liên hệ</a></li>
              <% if (session.user && session.user.PhanQuyen === 'Admin') { %>
                  <li><a href="/admin/dashboard">Quản trị</a></li>
              <% } %>
          </ul>
          <div class="user-menu">
  <% if (!session.user) { %>
      <a href="/khachhang/dangky" class="btn">Đăng ký</a>
      <a href="/khachhang/dangnhap" class="btn">Đăng nhập</a>
  <% } else { %>
      <span class="username">👤 <%= session.user.TaiKhoan %></span>

      <% if (session.user.PhanQuyen === 'NhaCungCap') { %>
          <a href="/nha-cung-cap/dashboard" class="btn">Quản lý chỗ ở</a>
      <% } else if (session.user.PhanQuyen === 'Admin') { %>
          <a href="/admin/dashboard" class="btn btn-warning">Trang quản trị</a>
      <% } else { %>
          <a href="/khachhang/quanlythongtin" class="btn">Tài khoản</a>
      <% } %>

      <a href="/khachhang/dangxuat" class="btn btn-logout">Đăng xuất</a>
  <% } %>
</div>

      </nav>
  </header>
