<header class="header">
    <nav class="navbar navbar-expand-lg bg-body-tertiary">
        <div class="container-fluid">
            <a
                href="/"
                class="navbar-brand"
                style="color: #ffffff; display: flex; align-items: center"
            >
                <div class="logo-inner" style="margin-right: 8px">
                    <img
                        src="/images/logo.png"
                        alt="logo"
                        sizes=""
                        srcset=""
                        class="d-block w-100"
                    />
                </div>
                <span>Tourist Management</span>
            </a>
            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarScroll"
                aria-controls="navbarScroll"
                aria-expanded="false"
                aria-label="Toggle navigation"
            >
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class=" navbar-collapse show" id="navbarScroll0">
                <ul
                    class="navbar-nav me-auto my-2 my-lg-0 navbar-nav-scroll color-white"
                    style="--bs-scroll-height: 100px"
                >
                    <li class="nav-item">
                        <a class="nav-link text-light" aria-current="page" href="/"
                            >Trang chủ</a
                        >
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-light" href="/phong">Phòng</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-light" href="/khachhang/don-dat-phong">Đơn đặt phòng</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-light" href="/lienhe">Liên hệ</a>
                    </li>
                    <% if (session.user && session.user.PhanQuyen === 'Admin') { %>
                     <li class="nav-item">
                        <a class="nav-link text-light" href="/admin/dashboard">Quản trị</a>
                    </li>
                    <% } %>
                </ul>
                <div class="user-menu">
                    <% if (!session.user) { %>
                    <a href="/khachhang/dangky" class="btn btn-primary">Đăng ký</a>
                    <a href="/khachhang/dangnhap" class="btn btn-primary">Đăng nhập</a>
                    <% } else { %>
                    <% if (session.user.PhanQuyen === 'NhaCungCap') { %>
                    <a href="/nha-cung-cap/dashboard" class="btn">Quản lý chỗ ở</a>
                    <% } else if (session.user.PhanQuyen === 'Admin') { %>
                    <a href="/admin/dashboard" class="btn btn-warning"
                        >Trang quản trị</a
                    >
                    <% } else { %>
                    <a href="/khachhang/thongtintaikhoan" class="username"
                        >👤 <%= session.user.TaiKhoan %></a
                    >
                    <% } %>

                    <a href="/khachhang/dangxuat" class="btn btn-logout btn-secondary">Đăng xuất</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>
</header>
