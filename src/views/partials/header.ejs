<!-- views/partials/header.ejs -->
<header class="header">
  <div class="container">
    <div class="header-left">
      <a href="/" class="logo">🏡 ThieuNu Travel</a>
      <nav class="main-nav">
        <ul>
          <li><a href="/">Trang chủ</a></li>
          <li><a href="/phong">Phòng</a></li>
          <li><a href="/lienhe">Liên hệ</a></li>
          <% if (session.user && session.user.PhanQuyen === 'Admin') { %>
            <li><a href="/admin/dashboard">Quản trị</a></li>
          <% } %>
        </ul>
      </nav>
    </div>

    <div class="user-menu">
      <% if (!session.user) { %>
        <a href="/khachhang/dangky" class="btn">Đăng ký</a>
        <a href="/khachhang/dangnhap" class="btn">Đăng nhập</a>
      <% } else { %>
        <span class="username">👤 <%= session.user.TaiKhoan %> </span>
        <a href="/khachhang/quanlytaikhoan" class="btn">Tài khoản</a>
        <a href="/dangxuat" class="btn btn-logout">Đăng xuất</a>
      <% } %>
    </div>
  </div>
</header>

<style>
  .header {
    background: #0077b6;
    color: #fff;
    padding: 10px 0;
    box-shadow: 0 2px 5px rgba(0,0,0,0.15);
  }

  .container {
    width: 90%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between; /* 👈 đẩy 2 bên ra xa nhau */
  }

  /* --- Logo & Menu bên trái --- */
  .header-left {
    display: flex;
    align-items: center;
    gap: 25px;
  }

  .logo {
    color: #fff;
    font-size: 22px;
    font-weight: 700;
    text-decoration: none;
  }

  .main-nav ul {
    list-style: none;
    display: flex;
    gap: 20px;
    margin: 0;
    padding: 0;
  }

  .main-nav a {
    color: #fff;
    text-decoration: none;
    font-weight: 500;
  }

  .main-nav a:hover {
    text-decoration: underline;
  }

  /* --- User Menu bên phải --- */
  .user-menu {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .user-menu .btn {
    background: #fff;
    color: #0077b6;
    border-radius: 6px;
    padding: 5px 12px;
    font-weight: 500;
    text-decoration: none;
    transition: 0.2s;
  }

  .user-menu .btn:hover {
    background: #caf0f8;
  }

  .user-menu .btn-logout {
    background: #ffdddd;
    color: #c0392b;
  }

  .user-menu .btn-logout:hover {
    background: #f5b7b1;
  }

  .username {
    font-weight: 600;
    color: #fff;
    margin-right: 6px;
  }
</style>
