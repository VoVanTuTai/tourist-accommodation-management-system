<div class="container py-5">
    <% if (error) { %>
      <div class="alert alert-danger text-center"><%= error %></div>
    <% } else { %>
      <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="row g-0">
          <div class="col-md-6">
            <img src="/uploads/<%= phong.HinhAnh %>" 
                 alt="<%= phong.TenPhong %>" 
                 class="img-fluid h-100 object-fit-cover">
          </div>
          <div class="col-md-6 p-5">
            <h2 class="fw-bold text-primary mb-3"><%= phong.TenPhong %></h2>
  
            <p><strong>Loại phòng:</strong> <%= phong.TenLoai %></p>
            <p><strong>Sức chứa:</strong> <%= phong.SucChua %> người</p>
            <p>
              <strong>Giá:</strong> 
              <span class="text-danger fw-bold fs-5">
                <%= phong.Gia.toLocaleString() %> VND/đêm
              </span>
            </p>
            <p>
              <strong>Địa chỉ:</strong> 
              <%= phong.DiaChiChiTiet %>, <%= phong.TenXa %>, <%= phong.TenTinh %>
            </p>
  
            <p>
              <strong>Trạng thái:</strong>
              <% if (phong.TinhTrang === 1) { %>
                <span class="badge bg-success">Còn phòng</span>
              <% } else if (phong.TinhTrang === 2) { %>
                <span class="badge bg-danger">Hết phòng</span>
              <% } else { %>
                <span class="badge bg-warning text-dark">Đang bảo trì</span>
              <% } %>
            </p>
  
            <hr>
            <p><strong>Mô tả:</strong></p>
            <p class="text-muted"><%= phong.MoTa || "Không có mô tả." %></p>
  
            <!-- ✅ Nút hành động -->
            <div class="mt-5 d-flex gap-3">
                <a href="/"
                class="btn fw-semibold px-4 py-2 rounded-pill shadow-lg text-white"
                style="
                   background: linear-gradient(90deg, #764ba2 0%, #667eea 100%);
                   border: none;
                   letter-spacing: 0.3px;
                   transition: all 0.3s ease;
                "
                onmouseover="this.style.background='linear-gradient(90deg, #6a11cb 0%, #2575fc 100%)'; this.style.transform='scale(1.05)';"
                onmouseout="this.style.background='linear-gradient(90deg, #764ba2 0%, #667eea 100%)'; this.style.transform='scale(1)';">
                ← Quay lại trang chủ
             </a>
  
              <% if (phong.TinhTrang === 1) { %>
                <a href="/khachhang/dat-phong/<%= phong.MaPhong %>" 
                   class="btn text-white fw-semibold px-4 py-2 rounded-pill shadow-sm"
                   style="background: linear-gradient(90deg, #6a11cb 0%, #2575fc 100%);">
                   <i class="fas fa-bed me-2"></i> Đặt phòng
                </a>
              <% } else { %>
                <button class="btn btn-secondary px-4 py-2 rounded-pill shadow-sm" disabled>
                  Không khả dụng
                </button>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </div>
<%- include('../partials/footer') %>
