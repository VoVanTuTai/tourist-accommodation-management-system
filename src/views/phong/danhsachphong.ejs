<h2>Danh sách phòng của nhà cung cấp</h2>

<table border="1" cellspacing="0" cellpadding="8">
  <thead>
    <tr>
      <th>Mã phòng</th>
      <th>Tên phòng</th>
      <th>Loại phòng</th>
      <th>Giá</th>
      <th>Sức chứa</th>
      <th>Tình trạng</th>
      <th>Hình ảnh</th>
      <th>Thao tác</th>
    </tr>
  </thead>
  <tbody>
    <% if (rooms.length === 0) { %>
      <tr><td colspan="8">Chưa có phòng nào</td></tr>
    <% } else { %>
      <% rooms.forEach(room => { %>
        <tr>
          <td><%= room.MaPhong %></td>
          <td><%= room.TenPhong %></td>
          <td><%= room.TenLoai %></td> <!-- ✅ Hiển thị tên loại -->
          <td><%= room.Gia.toLocaleString() %>₫</td>
          <td><%= room.SucChua %></td>
          <td>
            <% if (room.TinhTrang == 1) { %>
              <span style="color:green;">Còn trống</span>
            <% } else if (room.TinhTrang == 0) { %>
              <span style="color:red;">Đã đặt</span>
            <% } else { %>
              <span style="color:orange;">Bảo trì</span>
            <% } %>
          </td>
          <td>
            <% if (room.HinhAnh) { %>
              <img src="/images/<%= room.HinhAnh %>" width="80" alt="Ảnh phòng">
            <% } else { %>
              <span>Chưa có ảnh</span>
            <% } %>
          </td>
          <td>
            <a href="/phong/edit/<%= room.MaPhong %>">✏️ Sửa</a> |
            <a href="/phong/status/<%= room.MaPhong %>">🔄 Trạng thái</a>
          </td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>
