<% function renderStars(rating) {
    let stars = "";
    let full = Math.floor(rating);
    let half = rating % 1 >= 0.5;
    let empty = 5 - full - (half ? 1 : 0);

    for (let i = 0; i < full; i++) stars += '<i class="fas fa-star text-yellow-400 mr-1"></i>';
    if (half) stars += '<i class="fas fa-star-half-alt text-yellow-400 mr-1"></i>';
    for (let i = 0; i < empty; i++) stars += '<i class="far fa-star text-yellow-400 mr-1"></i>';

    return stars;
} %>

<div class="font-sans">

    <!-- ========================= -->
    <!-- 🌄 HERO SECTION -->
    <!-- ========================= -->
    <section 
    class="relative z-[1] overflow-hidden bg-cover bg-center min-h-[60vh] flex items-center"
        style="background-image: url('/images/bgr.webp');"
    >
        <div class="absolute inset-0 bg-black/20"></div>

        <div class="relative z-10 container mx-auto px-6 text-center text-white">
            <h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight">
                Chào mừng đến với hệ thống quản lý
                <span class="text-yellow-300">chỗ ở du lịch</span>
            </h1>

            <p class="text-xl md:text-2xl mb-8 text-gray-200 leading-relaxed">
                Đặt phòng dễ dàng, quản lý nhanh chóng và hiện đại.
            </p>

            <a href="/phong"
                class="inline-flex items-center bg-white text-purple-600 px-8 py-4
                    rounded-full text-lg font-semibold hover:bg-gray-100 transition-all
                    duration-300 shadow-lg hover:shadow-xl transform hover:scale-105">
                <i class="fa-solid fa-bed mr-3 text-xl"></i>
                Xem tất cả phòng
            </a>
        </div>
    </section>



    <!-- ========================= -->
    <!-- 🔍 SEARCH SECTION -->
    <!-- ========================= -->
    <div id="searchBarWrapper" 
        class="absolute top-[450px] left-1/2 -translate-x-1/2 w-[100%]  z-[99999]">
        <%- include("partials/timkiem") %>
    </div>


    <!-- ========================= -->
        <!-- 🏆 TOP ROOMS -->
        <!-- ========================= -->
        <section class="py-20" style="margin-top: 130px;">
            <div class="container mx-auto px-6">

                <!-- GLASS TITLE -->
                <div class="text-center mb-12">
                    <div class="glass-title-box mx-auto">
                        <h2 class="section-heading mb-0">
                            <i class="bi bi-trophy-fill"></i> Phòng được đặt nhiều nhất
                        </h2>
                    </div>
                </div>

                <% if (topRooms && topRooms.length > 0) { %>

                <div class="row">
                    <% topRooms.forEach(room => { %>

                    <div class="col-md-4 mb-4">
                        <div class="room-card card">

                            <!-- 📌 Lấy hình ảnh đầu tiên -->
                            <% 
                                let imgArr = [];
                                try { imgArr = JSON.parse(room.HinhAnh); } catch(e) {}
                                let firstImg = imgArr.length > 0 ? imgArr[0] : null;
                            %>

                            <!-- ẢNH -->
                            <img 
                                src="<%= firstImg ? '/images/' + firstImg : '/images/no-image.jpg' %>"
                                class="card-img-top"
                                style="height: 220px; object-fit: cover;"
                                alt="Ảnh phòng"
                            />

                            <div class="card-body">

                                <!-- Tên + lượt đặt -->
                                <h5 class="card-title d-flex justify-content-between align-items-center">
                                    <span><%= room.ten_phong %></span>
                                    <span class="badge bg-warning text-dark" style="font-size: .85rem;">
                                        🔥 <%= room.so_luot_dat %> lượt đặt
                                    </span>
                                </h5>

                                <!-- giá + đánh giá -->
                                <p class="card-text mb-2">

                                    <strong>Giá:</strong>
                                    <%= room.Gia ? room.Gia.toLocaleString() : "Chưa cập nhật" %> ₫ / đêm <br>

                                    <strong>Đánh giá:</strong>
                                    <span><%- renderStars(room.DanhGia || 0) %></span>
                                    <span class="text-muted">( <%= room.DanhGia ? room.DanhGia.toFixed(1) : "0.0" %> )</span>
                                </p>

                                <!-- Nút -->
                                <a href="/phong/chi-tiet/<%= room.MaPhong %>" 
                                    class="btn custom-gradient-btn w-100">
                                    Xem chi tiết
                                </a>

                            </div>

                        </div>
                    </div>

                    <% }) %>
                </div>

                <% } else { %>

                <div class="text-center py-16">
                    <div class="text-6xl mb-4">🏨</div>
                    <p class="text-xl text-gray-500 mb-2">Chưa có dữ liệu đặt phòng.</p>
                    <p class="text-gray-400">Hãy quay lại sau để xem các phòng phổ biến nhất!</p>
                </div>

                <% } %>

            </div>
        </section>
    <!-- ========================= -->
    <!-- 💎 WHY CHOOSE US -->
    <!-- ========================= -->
    <section class="py-20">
        <div class="container mx-auto px-6">

            <div class="text-center mb-12">
                <h3 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4">
                    Tại sao chọn chúng tôi?
                </h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

                <div class="text-center p-6">
                    <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-clock text-3xl text-purple-600"></i>
                    </div>
                    <h4 class="text-xl font-semibold mb-2">Đặt phòng 24/7</h4>
                    <p class="text-gray-600">Hệ thống hoạt động liên tục, đặt phòng mọi lúc mọi nơi</p>
                </div>

                <div class="text-center p-6">
                    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-shield-alt text-3xl text-green-600"></i>
                    </div>
                    <h4 class="text-xl font-semibold mb-2">Bảo mật tuyệt đối</h4>
                    <p class="text-gray-600">Thông tin cá nhân được bảo vệ an toàn tuyệt đối</p>
                </div>

                <div class="text-center p-6">
                    <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-headset text-3xl text-orange-600"></i>
                    </div>
                    <h4 class="text-xl font-semibold mb-2">Hỗ trợ tận tình</h4>
                    <p class="text-gray-600">Đội ngũ chăm sóc khách hàng chuyên nghiệp</p>
                </div>

            </div>

        </div>
    </section>

</div>
