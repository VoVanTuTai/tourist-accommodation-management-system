<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <title>Danh sách Phòng</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
  <header class="bg-blue-600 text-white text-center py-4 text-2xl font-semibold">
    DANH SÁCH PHÒNG
  </header>

  <main class="container mx-auto py-8 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 px-4">
    <% rooms.forEach(room => { %>
      <div class="bg-white shadow-lg rounded-xl overflow-hidden hover:shadow-xl transition-shadow">
        <img src="<%= room.HinhAnh %>" alt="Ảnh phòng" class="w-full h-48 object-cover">
        <div class="p-4">
          <h3 class="text-lg font-bold mb-1"><%= room.LoaiPhong %></h3>
          <p class="text-sm text-gray-600 mb-2">Nhà cung cấp: <%= room.NhaCungCap %></p>
          <p class="text-gray-700 font-semibold mb-1">Giá: <%= room.Gia.toLocaleString() %> VNĐ</p>
          <p class="text-gray-600">Sức chứa: <%= room.SucChua %> người</p>
          <p class="text-sm text-green-600 mt-1">Tình trạng: <%= room.TinhTrang %></p>
        </div>
      </div>
    <% }) %>
  </main>
</body>
</html>
