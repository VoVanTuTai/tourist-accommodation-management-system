<div class="wrap-register" style="max-width: 700px; margin: 0 auto; padding: 50px 0;">
    <div class="partner-register-container py-3 px-4 border rounded-3">
        <h3 class="modal-title text-uppercase text-center">Thông Tin Đăng Ký</h3>
        <form action="/nhacungcap/dangky" method="POST" id="partner-register-form" class="py-3 px-3">
            <div class="row mb-3">
                <div class="col-3">
                    <label for="TenNCC" class="form-label">Tên NCC</label>
                </div>
                <div class="col-9">
                    <input type="text" class="form-control" name="TenNCC" id="TenNCC" value="<% if (formData) formData.TenNCC %>" />
                    <span class="text-danger d-block text-error-TenNCC">
                        <% if (errors) { %>
                            <%= errors.TenNCC %>
                        <% } %>
                    </span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-3">
                    <label for="Email" class="form-label">Email</label>
                </div>
                <div class="col-9">
                    <input type="text" class="form-control" name="Email" id="Email" />
                    <span class="text-danger d-block text-error-email">
                        <% if (errors) { %>
                            <%= errors.Email %>
                        <% } %>
                    </span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-3">
                    <label for="Phone" class="form-label">SDT</label>
                </div>
                <div class="col-9">
                    <input type="text" class="form-control" name="Phone" id="Phone" />
                    <span class="text-danger d-block text-error-phone">
                        <% if (errors) { %>
                            <%= errors.Phone %>
                        <% } %>
                    </span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-3">
                    <label for="ThongTinThanhToan" class="form-label">Thông Tin Thanh Toán</label>
                </div>
                <div class="col-9">
                    <select
                        class="form-select form-select-md mb-3"
                        name="LoaiNganHang"
                        id="LoaiNganHang"
                    >
                        <option value="" selected>Select one</option>
                        <option value="VCB">Vietcombank</option>
                        <option value="VTB">VietinBank</option>
                        <option value="TCB">Techcombank</option>
                        <option value="MBB">MBBank</option>
                    </select>
                    <span class="text-danger d-block text-error-LoaiNganHang">
                        <% if (errors) { %>
                            <%= errors.LoaiNganHang %>
                        <% } %>
                    </span>
                    <input type="text" class="form-control" name="ThongTinThanhToan" id="ThongTinThanhToan" 
                        placeholder="e.g: 123456789"/>
                    <span class="text-danger d-block text-error-ThongTinThanhToan">
                        <% if (errors) { %>
                            <%= errors.ThongTinThanhToan %>
                        <% } %>
                    </span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-3">
                    <label for="LoaiHinh" class="form-label">Loại Hình</label>
                </div>
                <div class="col-9">
                    <select
                        class="form-select form-select-md"
                        name="LoaiHinh"
                        id="LoaiHinh"
                    >
                        <option value="" selected>Select one</option>
                        <option value="NhaNghi">Nhà Nghỉ</option>
                        <option value="Homestay">Homestay</option>
                        <option value="Hotel">Khách Sạn</option>
                        <option value="Villa">Villa</option>
                    </select>
                    <span class="text-danger d-block text-error-LoaiHinh">
                        <% if (errors) { %>
                            <%= errors.LoaiHinh %>
                        <% } %>
                    </span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-3">
                    <label for="GiayPhepKD" class="form-label">Giấy Phép KD</label>
                </div>
                <div class="col-9">
                    <input type="file" class="form-control" name="GiayPhepKD" id="GiayPhepKD" />
                    <span class="text-danger d-block text-error-GiayPhepKD"></span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-3">
                    <label for="Password" class="form-label">Password</label>
                </div>
                <div class="col-9">
                    <input type="password" class="form-control" name="Password" id="Password" />
                    <span class="text-danger d-block text-error-Password">
                        <% if (errors) { %>
                            <%= errors.Password %>
                        <% } %>
                    </span>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-3">
                    <label for="ConfirmPassword" class="form-label">Confirm Password</label>
                </div>
                <div class="col-9">
                    <input type="password" class="form-control" name="ConfirmPassword" id="ConfirmPassword" />
                    <span class="text-danger d-block text-error-ConfirmPassword">
                        <% if (errors) { %>
                            <%= errors.ConfirmPassword %>
                        <% } %>
                    </span>
                </div>
            </div>
            <div class="d-flex justify-content-center gap-2">
                <button
                    type="submit"
                    class="btn btn-primary btn-register-partner"
                    id="btn-register-partner">Đăng Ký</button>
                <a href="/" class="btn btn-danger btn-register-partner">Huỷ</a>
            </div>
        </form>
    </div>
</div>

<style>
    .btn-register-partner {
        min-width: 100px;
        text-align: center;
        font-size: 24px;
        width: 30%;
    }
</style>