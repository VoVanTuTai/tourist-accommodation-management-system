  <script src="/_sdk/element_sdk.js"></script>
  <style>@view-transition { navigation: auto; }</style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
  <script src="https://cdn.tailwindcss.com" type="text/javascript"></script>
<body>
  <div class="container">
    <div class="page-header">
      <h2 id="pageTitle">🏨 Danh sách phòng của <%= ncc.TenNCC %></h2>
    </div>
    <div class="action-bar">
      <form method="GET" action="/nhacungcap/phong" class="filter-form">
        <label for="filter" id="filterLabel"><strong>Lọc theo tình trạng:</strong></label>
        <select name="filter" id="filter" onchange="this.form.submit()">
          <option value="all" <%= currentFilter === 'all' ? 'selected' : '' %>>Tất cả</option>
          <option value="1" <%= currentFilter === '1' ? 'selected' : '' %>>🟢 Còn trống</option>
          <option value="0" <%= currentFilter === '0' ? 'selected' : '' %>>🔴 Đã đặt</option>
          <option value="2" <%= currentFilter === '2' ? 'selected' : '' %>>🟠 Bảo trì</option>
        </select>
      </form>

      <a href="/nhacungcap/phong/them" class="add-button" id="addButton">
    ➕ <span>Thêm phòng</span>
    </a>
    </div>
    <div class="table-container">
    <table class="table-striped table-bordered table-hover align-middle">
      <thead class="table-light">
      <tr>
        <th>Mã phòng</th>
        <th>Tên phòng</th>
        <th>Loại phòng</th>
        <th>Giá (VNĐ)</th>
        <th>Sức chứa</th>
        <th>Tình trạng</th>
        <th>Địa chỉ</th>
        <th>Hình ảnh</th>
        <th>Hành động</th>
      </tr>
    </thead>
     <tbody>
      <% if (rooms.length === 0) { %> 
        <tr>
          <td colspan="9" class="empty-state">Không có phòng nào</td>
        </tr>
      <% } else { %>
        <% rooms.forEach(p => { %> 
          <tr>
            <td><strong><%= p.MaPhong %></strong></td>
            <td><%= p.TenPhong %></td>
            <td><%= p.TenLoai %></td>
            <td class="price"><%= Number(p.Gia).toLocaleString() %></td>
            <td><%= p.SucChua %> người</td>

            <td>
              <% if (p.TinhTrang === 1) { %>
                <span class="status-badge status-available">🟢 Còn trống</span>
              <% } else if (p.TinhTrang === 0) { %>
                <span class="status-badge status-booked">🔴 Đã đặt</span>
              <% } else { %>
                <span class="status-badge status-maintenance">🟠 Bảo trì</span>
              <% } %>
            </td>

            <td>
              <% if (p.ChiTiet && p.TenXa && p.TenTinh) { %>
                <div class="address">
                  <%= p.ChiTiet %>, <%= p.TenXa %>, <%= p.TenTinh %>
                </div>
              <% } else { %>
                <span style="color:#cbd5e0;">—</span>
              <% } %>
            </td>

            <td>
              <% if (p.HinhAnh) { 
                  let firstImage = "";
                  try {
                    if (p.HinhAnh.trim().startsWith("[")) {
                      // Nếu là JSON array → lấy phần tử đầu tiên
                      const arr = JSON.parse(p.HinhAnh);
                      if (arr.length > 0) firstImage = arr[0];
                    } else {
                      // Nếu chỉ là chuỗi đơn
                      firstImage = p.HinhAnh;
                    }
                  } catch (err) {
                    firstImage = p.HinhAnh;
                  }
              %>
                <% if (firstImage) { %>
                  <img src="/images/<%= firstImage %>" class="room-image" alt="<%= p.TenPhong %>">
                <% } else { %>
                  <span style="color:#cbd5e0;">—</span>
                <% } %>
              <% } else { %>
                <span style="color:#cbd5e0;">—</span>
              <% } %>
            </td>

            <td>
              <div class="action-links">
                <a href="/nhacungcap/phong/chitiet/<%= p.MaPhong %>" class="action-view">👁️ Xem</a>

                <% if (p.TinhTrang === 0) { %>
                  <span class="action-disabled">🚫 Không thể thao tác</span>
                <% } else if (p.TinhTrang === 1) { %>
                  <a href="/nhacungcap/phong/trangthai/<%= p.MaPhong %>" class="action-update">🔄 Cập nhật</a>
                <% } else if (p.TinhTrang === 2) { %>
                  <a href="/nhacungcap/phong/suaphong/<%= p.MaPhong %>" class="action-edit">✏️ Sửa</a>
                  <a href="/nhacungcap/phong/trangthai/<%= p.MaPhong %>" class="action-update">🔄 Cập nhật</a>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %> 
      <% } %>
    </tbody>

    </table>
   </div>
  </div>
  <script>
    const defaultConfig = {
      page_title: "🏨 Danh sách phòng của",
      filter_label: "Lọc theo tình trạng:",
      add_button_text: "Thêm phòng",
      primary_color: "#667eea",
      secondary_color: "#48bb78",
      background_color: "#764ba2",
      text_color: "#2d3748",
      surface_color: "#ffffff"
    };

    const config = window.elementSdk?.config || defaultConfig;

    async function onConfigChange(config) {
      const pageTitle = document.getElementById('pageTitle');
      const filterLabel = document.getElementById('filterLabel');
      const addButton = document.getElementById('addButton');

      if (pageTitle) {
        const titleText = config.page_title || defaultConfig.page_title;
        const supplierName = pageTitle.textContent.split('của ')[1] || '';
        pageTitle.textContent = `${titleText}${supplierName ? ' của ' + supplierName : ''}`;
      }

      if (filterLabel) {
        filterLabel.innerHTML = `<strong>${config.filter_label || defaultConfig.filter_label}</strong>`;
      }

      if (addButton) {
        addButton.querySelector('span').textContent = config.add_button_text || defaultConfig.add_button_text;
      }

      const primaryColor = config.primary_color || defaultConfig.primary_color;
      const secondaryColor = config.secondary_color || defaultConfig.secondary_color;
      const backgroundColor = config.background_color || defaultConfig.background_color;
      const textColor = config.text_color || defaultConfig.text_color;
      const surfaceColor = config.surface_color || defaultConfig.surface_color;

      document.body.style.background = `linear-gradient(135deg, ${primaryColor} 0%, ${backgroundColor} 100%)`;
      
      const container = document.querySelector('.container');
      if (container) container.style.background = surfaceColor;

      const pageHeader = document.querySelector('.page-header');
      if (pageHeader) {
        pageHeader.style.borderBottomColor = primaryColor;
        pageHeader.querySelector('h2').style.color = textColor;
      }

      const addBtn = document.querySelector('.add-button');
      if (addBtn) {
        addBtn.style.background = `linear-gradient(135deg, ${secondaryColor} 0%, ${secondaryColor}dd 100%)`;
      }

      const thead = document.querySelector('thead');
      if (thead) {
        thead.style.background = `linear-gradient(135deg, ${primaryColor} 0%, ${backgroundColor} 100%)`;
      }

      const allText = document.querySelectorAll('tbody td');
      allText.forEach(td => {
        if (!td.querySelector('.status-badge') && !td.querySelector('.action-links')) {
          td.style.color = textColor;
        }
      });
    }

    if (window.elementSdk) {
      window.elementSdk.init({
        defaultConfig,
        onConfigChange,
        mapToCapabilities: (config) => ({
          recolorables: [
            {
              get: () => config.primary_color || defaultConfig.primary_color,
              set: (value) => {
                config.primary_color = value;
                window.elementSdk.setConfig({ primary_color: value });
              }
            },
            {
              get: () => config.secondary_color || defaultConfig.secondary_color,
              set: (value) => {
                config.secondary_color = value;
                window.elementSdk.setConfig({ secondary_color: value });
              }
            },
            {
              get: () => config.background_color || defaultConfig.background_color,
              set: (value) => {
                config.background_color = value;
                window.elementSdk.setConfig({ background_color: value });
              }
            },
            {
              get: () => config.text_color || defaultConfig.text_color,
              set: (value) => {
                config.text_color = value;
                window.elementSdk.setConfig({ text_color: value });
              }
            },
            {
              get: () => config.surface_color || defaultConfig.surface_color,
              set: (value) => {
                config.surface_color = value;
                window.elementSdk.setConfig({ surface_color: value });
              }
            }
          ],
          borderables: [],
          fontEditable: undefined,
          fontSizeable: undefined
        }),
        mapToEditPanelValues: (config) => new Map([
          ["page_title", config.page_title || defaultConfig.page_title],
          ["filter_label", config.filter_label || defaultConfig.filter_label],
          ["add_button_text", config.add_button_text || defaultConfig.add_button_text]
        ])
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      onConfigChange(config);
    });
  </script>
