<h2>➕ Thêm phòng mới</h2>

<form action="/nhacungcap/phong/them" method="POST" enctype="multipart/form-data" style="width: 70%; margin:auto;">
  <div style="margin-bottom: 10px;">
    <label><strong>Tên phòng:</strong></label><br>
    <input type="text" name="TenPhong" required style="width:100%;">
  </div>

  <div style="margin-bottom: 10px;">
    <label><strong>Loại phòng:</strong></label><br>
    <select name="MaLoai" required style="width:100%;">
      <% loaiPhongs.forEach(loai => { %>
        <option value="<%= loai.MaLoai %>"><%= loai.TenLoai %></option>
      <% }) %>
    </select>
  </div>

  <div style="margin-bottom: 10px;">
    <label><strong>Giá (VND):</strong></label><br>
    <input type="number" name="Gia" min="0" required style="width:100%;">
  </div>

  <div style="margin-bottom: 10px;">
    <label><strong>Sức chứa:</strong></label><br>
    <input type="number" name="SucChua" min="1" required style="width:100%;">
  </div>

  <!-- 📝 Thêm trường MÔ TẢ -->
  <div style="margin-bottom: 10px;">
    <label><strong>Mô tả:</strong></label><br>
    <textarea name="MoTa" rows="4" placeholder="Mô tả đặc điểm, tiện nghi, hướng view của phòng..." style="width:100%;"></textarea>
  </div>

  <hr>

  <div style="margin-bottom: 10px;">
    <label><strong>Địa chỉ:</strong></label><br>

    <select name="MaTinh" id="MaTinh" required onchange="filterXa()" style="width:100%; margin-bottom: 10px;">
      <option value="">-- Chọn tỉnh --</option>
      <% tinhs.forEach(t => { %>
        <option value="<%= t.MaTinh %>"><%= t.TenTinh %></option>
      <% }) %>
    </select>

    <select name="MaXa" id="MaXa" required style="width:100%;">
      <option value="">-- Chọn xã --</option>
      <% xas.forEach(x => { %>
        <option value="<%= x.MaXa %>" data-tinh="<%= x.MaTinh %>"><%= x.TenXa %></option>
      <% }) %>
    </select>

    <input type="text" name="ChiTietDiaChi" placeholder="Số nhà, đường, thôn..." required style="width:100%; margin-top:10px;">
  </div>

  <div style="margin-bottom: 10px;">
    <label><strong>Hình ảnh:</strong></label><br>
    <input type="file" name="HinhAnh" accept="image/*">
  </div>

  <div style="margin-top: 20px;">
    <button type="submit">💾 Lưu phòng</button>
    <a href="/nhacungcap/phong" style="margin-left:10px;">⬅️ Quay lại</a>
  </div>
</form>

<script>
  function filterXa() {
    const maTinh = document.getElementById('MaTinh').value;
    const options = document.querySelectorAll('#MaXa option');
    options.forEach(o => {
      if (!o.value) return;
      o.style.display = o.dataset.tinh === maTinh ? 'block' : 'none';
    });
  }
</script>
