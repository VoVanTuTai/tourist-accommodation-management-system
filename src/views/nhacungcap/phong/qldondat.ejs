    <div class="container mt-5">
        <h1 class="mb-4">📋 Quản lý Đơn Đặt Phòng</h1>
        <hr>

        <table class="table table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Mã Đơn</th>
                    <th>Mã KH</th>
                    <th>Người Nhận</th>
                    <th>SĐT</th>
                    <th>Ngày Đặt</th>
                    <th>Ngày Nhận</th>
                    <th>Ngày Trả</th>
                    <th>Tổng Tiền</th>
                    <th>Trạng Thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <% if (orders.length > 0) { %>
                    <% orders.forEach(order => { %>
                        <tr>
                            <td><%= order.MaDon %></td>
                            <td><%= order.MaKhachHang %></td>
                            <td><%= order.TenNguoiNhan %></td>
                            <td><%= order.SDTNguoiNhan %></td>
                            <td><%= new Date(order.NgayDat).toLocaleDateString('vi-VN') %></td>
                            <td><%= new Date(order.NgayNhan).toLocaleDateString('vi-VN') %></td>
                            <td><%= new Date(order.NgayTra).toLocaleDateString('vi-VN') %></td>
                            <td><%= order.TongTien.toLocaleString('vi-VN') %> VNĐ</td>
                            <td>
                                <span class="badge bg-<%= 
                                    order.TrangThai === 2 ? 'success' : 
                                    order.TrangThai === 2 ? 'primary' : 
                                    order.TrangThai === 3 ? 'warning' : 'danger' 
                                %>">
                                    <%= getStatusText(order.TrangThai) %>
                                </span>
                            </td>
                            <td>
                                <form action="/update-status/<%= order.MaDon %>" method="POST" class="d-inline">
                                    <select name="newStatus" class="form-select form-select-sm d-inline-block w-auto me-2">
                                        <option value="1" <%= order.TrangThai === 1 ? 'selected' : '' %>>Chờ Xác Nhận</option>
                                        <option value="2" <%= order.TrangThai === 2 ? 'selected' : '' %>>Đã Nhận Phòng</option>
                                        <option value="3" <%= order.TrangThai === 3 ? 'selected' : '' %>>Đã Thanh Toán</option>
                                        <option value="0" <%= order.TrangThai === 0 ? 'selected' : '' %>>Hủy Đơn</option>
                                    </select>
                                    <button type="submit" class="btn btn-info btn-sm">Cập nhật</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="10" class="text-center">Không có đơn đặt phòng nào.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>