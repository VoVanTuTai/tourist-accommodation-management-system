<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Sửa thông tin phòng</title>
  <style>
    body { font-family: "Segoe UI", sans-serif; background: #f5f6f7; }
    .container { max-width: 800px; margin: 40px auto; background: #fff; padding: 20px; border-radius: 12px; box-shadow: 0 0 10px rgba(0,0,0,0.1); }
    label { display: block; margin-top: 10px; font-weight: bold; }
    input, select { width: 100%; padding: 8px; margin-top: 5px; border-radius: 6px; border: 1px solid #ccc; }
    button { margin-top: 20px; width: 100%; padding: 10px; background: #007bff; border: none; color: white; font-size: 16px; border-radius: 6px; cursor: pointer; }
    button:hover { background: #0056b3; }
  </style>
</head>
<body>
<div class="container">
  <h2>Sửa thông tin phòng</h2>
  <form action="/nhacungcap/phong/suaphong" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="MaPhong" value="<%= phong.MaPhong %>">

    <label>Tên phòng:</label>
    <input type="text" name="TenPhong" value="<%= phong.TenPhong %>" required>

    <label>Loại phòng:</label>
    <select name="MaLoai" required>
      <% loaiPhongs.forEach(lp => { %>
        <option value="<%= lp.MaLoai %>" <%= lp.MaLoai === phong.MaLoai ? 'selected' : '' %>><%= lp.TenLoai %></option>
      <% }) %>
    </select>

    <label>Giá (VNĐ):</label>
    <input type="number" name="Gia" value="<%= phong.Gia %>" required>

    <label>Sức chứa:</label>
    <input type="number" name="SucChua" value="<%= phong.SucChua %>" required>

    <label>Tình trạng:</label>
    <select name="TinhTrang" required>
      <option value="Trống" <%= phong.TinhTrang === 'Trống' ? 'selected' : '' %>>Trống</option>
      <option value="Đang thuê" <%= phong.TinhTrang === 'Đang thuê' ? 'selected' : '' %>>Đang thuê</option>
    </select>

    <hr>
    <h3>Địa chỉ phòng</h3>

    <label>Chi tiết địa chỉ:</label>
    <input type="text" name="ChiTietDiaChi" value="<%= diaChiHienTai ? diaChiHienTai.ChiTiet : '' %>" required>

    <label>Tỉnh:</label>
    <select name="MaTinh" id="selectTinh" required>
      <% tinhs.forEach(t => { %>
        <option value="<%= t.MaTinh %>" <%= diaChiHienTai && t.MaTinh === diaChiHienTai.MaTinh ? 'selected' : '' %>><%= t.TenTinh %></option>
      <% }) %>
    </select>

    <label>Xã:</label>
    <select name="MaXa" id="selectXa" required>
      <% xas.forEach(x => { %>
        <option value="<%= x.MaXa %>" data-tinh="<%= x.MaTinh %>" <%= diaChiHienTai && x.MaXa === diaChiHienTai.MaXa ? 'selected' : '' %>>
          <%= x.TenXa %>
        </option>
      <% }) %>
    </select>

    <script>
      const selectTinh = document.getElementById('selectTinh');
      const selectXa = document.getElementById('selectXa');
      const allXaOptions = Array.from(selectXa.options);

      function filterXaByTinh() {
        const tinhValue = selectTinh.value;
        selectXa.innerHTML = '';
        allXaOptions.forEach(opt => {
          if (opt.dataset.tinh === tinhValue) {
            selectXa.appendChild(opt);
          }
        });
      }

      selectTinh.addEventListener('change', filterXaByTinh);
      filterXaByTinh(); // gọi lần đầu để lọc đúng xã của tỉnh hiện tại
    </script>

    <label>Ảnh phòng:</label>
    <% if (phong.HinhAnh) { %>
      <img src="/images/<%= phong.HinhAnh %>" width="120">
    <% } %>
    <input type="file" name="HinhAnh">

    <button type="submit">Cập nhật phòng</button>
  </form>
</div>
</body>
</html>
