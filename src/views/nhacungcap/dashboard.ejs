                {
                    ticks: {
                        min: 0,
                        max: maxDoanhThuTheoThang || 60000,
                        maxTicksLimit: 5,
                    },
                    gridLines: {
                        color: "rgba(0, 0, 0, .125)",
                    },
                },
            ],
        },
        legend: {
            display: false,
        },
    },
})
</script>

<script>
