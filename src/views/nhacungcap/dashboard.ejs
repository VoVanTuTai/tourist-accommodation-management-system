        responsive: true,
        plugins: {
            legend: {
                position: "top",
            },
            title: {
                display: true,
                text: "Chart.js Pie Chart",
            },
        },
        onClick: function (evt) {
            console.log("Chart.js Pie Chart click event:", evt);
            const activePoints = myBookingChart.getElementsAtEventForMode(evt, 'nearest', {
                intersect: true
            }, false);
            if (activePoints.length > 0) {
                const index = activePoints[0]._index;
                const label = myBookingChart.data.labels[index];
                const value = myBookingChart.data.datasets[0].data[index];
                const newWindow = window.open('', '_blank');
                newWindow.location.href = `/nhacungcap/don-dat-phong?trangThai=${index}`;
            }
        },
    },
}
const myBookingChart = new Chart(ctxBooking, configBooking);
</script>
<script src="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/umd/simple-datatables.min.js" crossorigin="anonymous"></script>
<script src="/js/nhacungcap/datatables.js"></script>

<script>
    $(function () {
        var myDate = $('#statsByMonth').attr('data-date');
        $('#statsByMonth').datepicker({
            maxDate: new Date(),
            changeMonth: true,
            changeYear: true,
            setDate: myDate,
            showButtonPanel: false,
            dateFormat: 'MM yy',
            onClose: function (dateText, inst) {
                var monthValue = $('#ui-datepicker-div .ui-datepicker-month :selected').val();
                var yearValue = $('#ui-datepicker-div .ui-datepicker-year :selected').val();
                const newDate = new Date(yearValue, monthValue, 1);
                $(this).datepicker('setDate', newDate);
                const month = (newDate.getMonth() + 1).toString().padStart(2, '0');
                const url = `/nhacungcap/statsByMonth/${month}-${newDate.getFullYear()}`;
                fetch(url, { // Replace with your backend endpoint
                    method: 'GET',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    console.log('Success:', data);
                    console.log(myLineChart)
                    const {maxDoanhThuTheoThang, doanhThuTheoThang } = data;
                    const labels = Object.keys(doanhThuTheoThang);
                    const values = Object.values(doanhThuTheoThang);
                    updateDataChart(myLineChart, labels, values);
                    updateMaxChart(myLineChart, maxDoanhThuTheoThang, "line");
                    // Optionally, update the chart with new data here
                })
                .catch((error) => {
                    console.error('Error:', error);
                    // alert('An error occurred while fetching data for the selected month.');
                    alert(error.message);
                });
            },
        });
        $('#statsByMonth').datepicker('setDate', myDate);
        $('#statsByMonth').focus(function () {
            $(".ui-datepicker-calendar").hide();
        });

        var myDate = $('#statsByYear').attr('data-date');
        $('#statsByYear').datepicker({
            maxDate: new Date(),
            changeMonth: false,
            changeYear: true,
            setDate: myDate,
            showButtonPanel: false,
            dateFormat: 'yy',
            onClose: function (dateText, inst) {
                var year = $("#ui-datepicker-div .ui-datepicker-year :selected").val();
                $(this).datepicker('setDate', new Date(year, 1));
                const url = `/nhacungcap/statsByYear/${year}`;
                fetch(url, { // Replace with your backend endpoint
                    method: 'GET',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    console.log('Success:', data);
                    console.log(myBarChart)
                    const {maxDoanhThuTheoNam, doanhThuThangTheoNam } = data;
                    const labels = Object.keys(doanhThuThangTheoNam);
                    const values = Object.values(doanhThuThangTheoNam);
                    updateDataChart(myBarChart, labels, values);
                    updateMaxChart(myBarChart, maxDoanhThuTheoNam, "bar");
                    // Optionally, update the chart with new data here
                })
                .catch((error) => {
                    console.error('Error:', error);
                    alert(error.message);
                });
            },
        });
        $('#statsByYear').datepicker('setDate', myDate);
        $('#statsByYear').focus(function () {
            $(".ui-datepicker-month").hide();
            $(".ui-datepicker-calendar").hide();
        });
    });
    function updateDataChart(chart, label, data) {
        chart.data.labels = label;
        chart.data.datasets.forEach((dataset) => {
            dataset.data = data;
        });
        chart.update();
    }

    function updateMaxChart(chart, maxValue, type = "bar") {
        let xScale = chart.scales.x;
        let yScale = chart.scales.y;
        chart.options = {
            scales: {
                xAxes: [
                    {
                        time: {
                            unit: type == "bar" ? "month" : "date",
                        },
                        gridLines: {
                            display: false,
                        },
                        ticks: {
                            maxTicksLimit: type == "bar" ? 6 : 7,
                        },
                    },
                ],
                yAxes: [
                    {
                        ticks: {
                            min: 0,
                            max: maxValue || 60000,
                            maxTicksLimit: 5,
                        },
                        gridLines: type == "bar" ? {
                            display: true,
                        } : {
                            color: "rgba(0, 0, 0, .125)"    
                        },
                    },
                ],
            },
            legend: {
                display: false,
            },
        }
        chart.update();
    }
</script>
<% } %>
