<script>
// Room Pie Chart
const thongKePhong = <%- JSON.stringify(data.thongKePhong) %>;

const dataRoom = {
    labels: Object.keys(thongKePhong),
    datasets: [
        {
            backgroundColor: ["#37a2eb", "#ff6384", "#4cc0c0"],
            // backgroundColor: ["#37a2eb", "#ff6384", "#ff9e40", "#4cc0c0", "#ffcd56"],
            data: Object.values(thongKePhong),
        },
    ],
}

const ctxRoomPieChart = document.getElementById("myRoomPieChart").getContext("2d");
const configRoomPieChart = {
    type: "pie",
    data: dataRoom,
    options: {
        responsive: true,
        plugins: {
            legend: {
                position: "top",
            },
            title: {
                display: true,
                text: "Chart.js Pie Chart",
            },
        },
        onClick: function (evt) {
            console.log("Chart.js Pie Chart click event:", evt);
            const activePoints = myChartRoomPieChart.getElementsAtEventForMode(evt, 'nearest', {
                intersect: true
            }, false);
            if (activePoints.length > 0) {
                const index = activePoints[0]._index;
                const label = myChartRoomPieChart.data.labels[index];
                const value = myChartRoomPieChart.data.datasets[0].data[index];
                const newWindow = window.open('', '_blank');
                newWindow.location.href = `/nhacungcap/phong?filter=${index}`;
            }
        },
    },
}
const myChartRoomPieChart = new Chart(ctxRoomPieChart, configRoomPieChart)


// Booking Pie Chart
const thongKeDonDatPhong = <%- JSON.stringify(data.thongKeDonDatPhong) %>;

const dataBooking = {
    labels: Object.keys(thongKeDonDatPhong),
    datasets: [
        {
            backgroundColor: ["#ff6384", "#4bc0c0", "#ff9e40"],
            data: Object.values(thongKeDonDatPhong),
        },
    ],
}

const ctxBooking = document.getElementById("myBookingPieChart").getContext("2d")
const configBooking = {
