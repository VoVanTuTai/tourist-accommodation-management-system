<% const f = formData || {}; %>

<div class="login-container">
  <div class="login-box">
    <h2>Đăng nhập tài khoản</h2>

    <%
      let success = null; 
      if (success=='true') { %>
      <div class="success-box">🎉 Đăng ký thành công! Vui lòng đăng nhập.</div>
    <% } %>

    <% if (errors && errors.Global) { %>
      <div class="error-box"><%= errors.Global %></div>
    <% } %>

    <form action="/nhacungcap/dangnhap" method="POST" class="login-form">
        <div class="row mb-3">
            <div class="col-3">
                <label for="Email" class="form-label">Email</label>
            </div>
            <div class="col-9">
                <input type="text" class="form-control" name="Email" id="Email" value="<%= f.Email || '' %>" />
                <span class="text-danger d-block text-error-email">
                    <% if (errors) { %>
                        <%= errors.Email %>
                    <% } %>
                </span>
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-3">
                <label for="Password" class="form-label">Password</label>
            </div>
            <div class="col-9">
                <input type="password" class="form-control" name="Password" id="Password" />
                <span class="text-danger d-block text-error-Password">
                    <% if (errors) { %>
                        <%= errors.Password %>
                    <% } %>
                </span>
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-3">
                
            </div>
            <div class="col-9">
                <input type="checkbox" id="rememberMe" name="rememberMe">
                <label for="rememberMe">Ghi nhớ đăng nhập</label>
            </div>
        </div>

      <div class="form-group submit">
        <button type="submit" class="btn-submit">Đăng nhập</button>
      </div>
    </form>

    <p class="text-center mt-3">
      Chưa có tài khoản? <a href="/nhacungcap/dangky">Đăng ký ngay</a>
    </p>
  </div>
</div>

<style>
  .login-container {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 40px 20px;
   
    min-height: 80vh;
  }

  .login-box {
    background: #fff;
    padding: 30px 40px;
    border-radius: 12px;
    box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    width: 100%;
    max-width: 420px;
  }

  .login-box h2 {
    text-align: center;
    color: #0077b6;
    margin-bottom: 25px;
  }

  .form-group {
    margin-bottom: 18px;
    display: flex;
    flex-direction: column;
  }

  label {
    font-weight: 500;
    margin-bottom: 5px;
    color: #333;
  }

  input[type="email"], input[type="password"] {
    padding: 8px 10px;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 15px;
    outline: none;
  }

  input:focus {
    border-color: #0077b6;
    box-shadow: 0 0 3px rgba(0,119,182,0.4);
  }

  .remember-me {
    flex-direction: row;
    align-items: center;
    gap: 6px;
  }

  .btn-submit {
    width: 100%;
    background: #0077b6;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 10px;
    font-size: 16px;
    cursor: pointer;
    transition: background 0.2s ease-in-out;
  }

  .btn-submit:hover {
    background: #005f8a;
  }

  .error-box, .success-box {
    padding: 10px 12px;
    border-radius: 6px;
    margin-bottom: 15px;
    text-align: center;
  }

  .error-box {
    background: #ffe6e6;
    border: 1px solid #ffcccc;
    color: #b00020;
  }

  .success-box {
    background: #e8f8e8;
    border: 1px solid #b8e6b8;
    color: #006400;
  }
</style>
