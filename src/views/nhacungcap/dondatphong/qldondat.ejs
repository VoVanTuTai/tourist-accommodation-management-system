<div class="container mt-5">
    <h1 class="mb-4">📋 Quản lý Đơn Đặt Phòng</h1>
    <hr>

    <form action="/nhacungcap/don-dat-phong" method="GET" class="mb-3">
        <div class="row g-3 align-items-center">
            
            <div class="col-auto">
                <label for="trangThai" class="col-form-label">Trạng Thái:</label>
            </div>
            <div class="col-auto">
                <select name="trangThai" id="trangThai" class="form-select" onchange="this.form.submit()">
                    <option value="">Tất Cả</option>
                    <option value="1" <%= currentStatus === '1' ? 'selected' : '' %>>Đang Sử Dụng</option>
                    <option value="2" <%= currentStatus === '2' ? 'selected' : '' %>>Đã Hoàn Tất</option>
                    <option value="3" <%= currentStatus === '3' ? 'selected' : '' %>>Đã Hủy</option>
                    <option value="0" <%= currentStatus === '0' ? 'selected' : '' %>>Chờ Xác Nhận</option>
                </select>
            </div>

            <div class="col-auto">
                <label for="searchMaDon" class="col-form-label">Tìm kiếm Mã Đơn:</label>
            </div>
            <div class="col-auto">
                <input type="text" name="searchMaDon" id="searchMaDon" 
                       class="form-control" placeholder="Nhập Mã Đơn..." 
                       value="<%= searchMaDon || '' %>">
            </div>
            
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Tìm</button>
            </div>

            <% if (currentStatus || searchMaDon) { %>
                <div class="col-auto">
                    <a href="/nhacungcap/don-dat-phong" class="btn btn-secondary">Xóa Lọc</a>
                </div>
            <% } %>

        </div>
    </form>
    <hr>

    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>Mã Đơn</th>
                <th>Mã KH</th>
                <th>Người Nhận</th>
                <th>SĐT</th>
                <th>Ngày Đặt</th>
                <th>Ngày Nhận</th> 
                <th>Ngày Trả</th>
                <th>Tổng Tiền</th>
                <th>Trạng Thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            <% if (orders.length > 0) { %>
                <% orders.forEach(order => { %>
                    <tr>
                        <td><%= order.MaDon %></td>
                        
                        <td><%= order.MaKhachHang %></td>
                        <td><%= order.TenNguoiNhan %></td>
                        <td><%= order.SDTNguoiNhan %></td>
                        <td><%= order.NgayDat %></td> 
                        <td><%= order.NgayNhan %></td>
                        
                        <td><%= order.NgayTra %></td>
                        <td><%= order.TongTien.toLocaleString('vi-VN') %> VNĐ</td>
                        <td>
                            <span class="badge bg-<%= 
                                order.TrangThai === 2 ? 'success' :      // Đã Hoàn Tất
                                order.TrangThai === 1 ? 'primary' :      // Đang Sử Dụng
                                order.TrangThai === 0 ? 'warning' :      // Chờ Xác Nhận
                                'danger'                                 // Đã Hủy (hoặc giá trị không xác định)
                            %>">
                                <%= getStatusText(order.TrangThai) %>
                            </span>
                        </td>
                        <td>
                            <a href="/nhacungcap/don-dat-phong/chitiet/<%= order.MaDon %>" class="btn btn-sm btn-outline-info me-2">
                                Chi tiết
                            </a>

                            <% 
                                // Cho phép cập nhật nếu Trạng thái là 0 (Chờ Xác Nhận) hoặc 1 (Đang Sử Dụng)
                                const canUpdate = order.TrangThai === 0 || order.TrangThai === 1;
                            %>

                            <% if (canUpdate) { %>
                                <form action="/nhacungcap/don-dat-phong/capnhat-trangthai/<%= order.MaDon %>" method="POST" class="d-inline">
                                    <select name="newStatus" class="form-select form-select-sm d-inline-block w-auto me-2">
                                        <option value="1" <%= order.TrangThai === 1 ? 'selected' : '' %>>Đang Sử Dụng</option>
                                        
                                        <% if (order.TrangThai === 1) { %>
                                            <option value="2" <%= order.TrangThai === 2 ? 'selected' : '' %>>Đã Hoàn Tất</option>
                                        <% } %>

                                        <option value="3" <%= order.TrangThai === 3 ? 'selected' : '' %>>Đã Hủy</option>
                                        <option value="0" <%= order.TrangThai === 0 ? 'selected' : '' %>>Chờ Xác Nhận</option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-success">Cập nhật</button>
                                </form>
                            <% } else { %>
                                <span class="text-muted small">Đã khóa thao tác</span>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="10" class="text-center py-4">
                        <i class="fas fa-box-open me-2"></i> Không có đơn đặt phòng nào phù hợp với điều kiện tìm kiếm.
                    </td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>