<h2>✏️ Chỉnh sửa phòng: <%= phong.TenPhong %></h2>

<form action="/ncc/phong/sua/<%= phong.MaPhong %>" method="POST" enctype="multipart/form-data" style="max-width: 600px;">
  <input type="hidden" name="MaPhong" value="<%= phong.MaPhong %>">

  <label>Tên phòng:</label><br>
  <input type="text" name="TenPhong" value="<%= phong.TenPhong %>" required><br><br>

  <label>Loại phòng:</label><br>
  <select name="MaLoai" required>
    <% loaiPhongs.forEach(lp => { %>
      <option value="<%= lp.MaLoai %>" <%= lp.MaLoai === phong.MaLoai ? 'selected' : '' %>>
        <%= lp.TenLoai %>
      </option>
    <% }) %>
  </select><br><br>

  <label>Giá (VNĐ):</label><br>
  <input type="number" name="Gia" value="<%= phong.Gia %>" required><br><br>

  <label>Sức chứa:</label><br>
  <input type="number" name="SucChua" value="<%= phong.SucChua %>" required><br><br>

  <label>Trạng thái:</label><br>
  <select name="TinhTrang" required>
    <option value="1" <%= phong.TinhTrang === 1 ? 'selected' : '' %>>Còn trống</option>
    <option value="0" <%= phong.TinhTrang === 0 ? 'selected' : '' %>>Đã đặt</option>
    <option value="2" <%= phong.TinhTrang === 2 ? 'selected' : '' %>>Bảo trì</option>
  </select><br><br>

  <label>Hình ảnh hiện tại:</label><br>
  <% if (phong.HinhAnh) { %>
    <img src="/images/<%= phong.HinhAnh %>" width="100"><br><br>
  <% } else { %>
    <p>Chưa có hình ảnh</p>
  <% } %>

  <label>Chọn hình ảnh mới (nếu muốn thay đổi):</label><br>
  <input type="file" name="HinhAnh" accept="image/*"><br><br>

  <button type="submit" style="padding: 8px 15px; background: #007bff; color: #fff; border: none; border-radius: 6px;">Cập nhật</button>
  <a href="/ncc/phong" style="margin-left:10px;">⬅️ Quay lại</a>
</form>
