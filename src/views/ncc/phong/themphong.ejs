<h2>Thêm phòng mới</h2>

<form action="/phong/add" method="POST" enctype="multipart/form-data">
  <label>Tên phòng:</label><br>
  <input type="text" name="TenPhong" required><br><br>
  <label>Loại phòng:</label><br>
  <select name="MaLoai" required>
  <% loaiPhongs.forEach(lp => { %>
    <option value="<%= lp.MaLoai %>"><%= lp.TenLoai %></option>
  <% }) %>
  </select><br>
  <label>Giá (VND):</label><br>
  <input type="number" name="Gia" required><br><br>

  <label>Sức chứa:</label><br>
  <input type="number" name="SucChua" required><br><br>

  <label>Tình trạng:</label><br>
  <select name="TinhTrang">
    <option value="1">Còn trống</option>
    <option value="0">Đã đặt</option>
  </select><br><br>

  <label>Hình ảnh:</label><br>
  <input type="file" name="HinhAnh" accept="image/*"><br><br>

  <button type="submit">Thêm phòng</button>
</form>
