<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Dashboard - Quản trị hệ thống</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    * { box-sizing: border-box; }

    body {
      font-family: "Segoe UI", sans-serif;

      background: #f4f6f9;
      color: #333;
    }

    header {
      background: #0d6efd;
      color: #fff;
      text-align: center;
      padding: 15px;
      font-size: 1.3em;
      font-weight: 600;
    }

  .container {
  width: 100%;
  max-width: 1700px;
  margin: 15px auto;
  display: grid;
  grid-template-columns: 1fr; /* Chỉ có 1 cột duy nhất */
  gap: 25px; /* Tạo khoảng cách giữa các hàng con */
}

    /* ===== NAV ===== */
    .nav-buttons {
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
    }

    .nav-buttons a {
      text-decoration: none;
      background: #0d6efd;
      color: #fff;
      padding: 14px 26px;
      border-radius: 10px;
      font-weight: 600;
      box-shadow: 0 3px 8px rgba(13,110,253,0.25);
      transition: all .25s ease;
    }

    .nav-buttons a:hover {
      background: #0b5ed7;
      transform: translateY(-2px);
    }

    /* ===== STATS ===== */
    .top-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
    }

    .stat-card {
      flex: 1 1 260px;
      min-width: 260px;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      padding: 22px;
      text-align: center;
      transition: transform .2s ease;
    }

    .stat-card:hover {
      transform: translateY(-3px);
    }

    .stat-card h3 {
      margin: 0;
      font-size: 1em;
      color: #0d6efd;
    }

    .stat-card p {
      font-size: 1.9em;
      font-weight: bold;
      margin: 12px 0 0;
    }

    /* ===== EXPORT ===== */
    .export-actions {
      display: flex;
      justify-content: flex-end;
      gap: 12px;
      flex-wrap: wrap;
    }

    .btn-export {
      background: #198754;
      color: #fff;
      border: none;
      padding: 10px 18px;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 600;
      box-shadow: 0 2px 6px rgba(25,135,84,.25);
    }

    .btn-export:hover {
      background: #157347;
    }

    /* ===== CHARTS ===== */
    .charts {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
    }

    .chart-box {
      flex: 1 1 520px;
      min-width: 420px;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      padding: 20px;
    }

    .chart-box canvas {
      max-height: 360px;
    }

    /* ===== TABLES ===== */
    .tables {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
    }

    .table-box {
      flex: 1 1 520px;
      min-width: 420px;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      padding: 20px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
    }

    table th, table td {
      border: 1px solid #dee2e6;
      padding: 8px 10px;
      text-align: center;
    }

    table th {
      background: #0d6efd;
      color: #fff;
    }

    footer {
      text-align: center;
      padding: 15px;
      background: #0d6efd;
      color: #fff;
      margin-top: 40px;
    }

    @media (max-width: 900px) {
      .chart-box, .table-box, .stat-card {
        min-width: 100%;
      }
    }
  </style>
</head>

<body>
<div class="nav-grey">...</div>
  <div style="height: 50px;"></div> 
  <header>📊 Bảng điều khiển quản trị hệ thống</header>

<div class="container">
  
  <!-- NAV -->
  <div class="nav-buttons">
    <a href="/admin/customers">👤 Quản lý khách hàng</a>
    <a href="/admin/providers">🏢 Quản lý nhà cung cấp</a>
    <a href="/admin/commission">💼 Thống kê hoa hồng</a>
  </div>

  <!-- STATS -->
  <div class="top-stats">
    <div class="stat-card">
      <h3>Khách hàng đang hoạt động</h3>
      <p><%= customerStats.active || 0 %></p>
    </div>

    <div class="stat-card">
      <h3>Nhà cung cấp đang hoạt động</h3>
      <p><%= providerStats.active || 0 %></p>
    </div>

    <div class="stat-card">
      <h3>Tổng tài khoản</h3>
      <p><%= (customerStats.total || 0) + (providerStats.total || 0) %></p>
    </div>

    <div class="stat-card">
      <h3>💰 Tổng hoa hồng</h3>
      <p style="color:#198754">
        <%= (totalCommission || 0).toLocaleString("vi-VN") %> VNĐ
      </p>
    </div>
  </div>

  <!-- EXPORT -->
  <div class="export-actions">
    <form action="/admin/dashboard/export" method="GET">
      <button class="btn-export">📄 Xuất PDF</button>
    </form>
    <form action="/admin/dashboard/export-excel" method="GET">
      <button class="btn-export" style="background:#1177ff">📊 Xuất Excel</button>
    </form>
  </div>

  <!-- CHARTS -->
  <div class="charts">
    <div class="chart-box">
      <h3>Thống kê khách hàng</h3>
      <canvas id="chartCustomer"></canvas>
    </div>
    <div class="chart-box">
      <h3>Thống kê nhà cung cấp</h3>
      <canvas id="chartProvider"></canvas>
    </div>
  </div>

  <!-- TABLES -->
  <div class="tables">
    <div class="table-box">
      <h3>Khách hàng</h3>
      <table>
        <tr><th>Loại</th><th>Số lượng</th></tr>
        <tr><td>Tổng</td><td><%= customerStats.total %></td></tr>
        <tr><td>Hoạt động</td><td><%= customerStats.active %></td></tr>
        <tr><td>Đã khóa</td><td><%= customerStats.locked %></td></tr>
      </table>
    </div>

    <div class="table-box">
      <h3>Nhà cung cấp</h3>
      <table>
        <tr><th>Loại</th><th>Số lượng</th></tr>
        <tr><td>Tổng</td><td><%= providerStats.total %></td></tr>
        <tr><td>Hoạt động</td><td><%= providerStats.active %></td></tr>
        <tr><td>Chờ duyệt</td><td><%= providerStats.pending %></td></tr>
        <tr><td>Đã khóa</td><td><%= providerStats.locked %></td></tr>
      </table>
    </div>
  </div>

</div>

<footer>© 2025 Tourist Accommodation Management System</footer>

<script>
  const customerStats = <%- JSON.stringify(customerStats) %>;
  const providerStats = <%- JSON.stringify(providerStats) %>;

  new Chart(document.getElementById("chartCustomer"), {
    type: "doughnut",
    data: {
      labels: ["Hoạt động", "Đã khóa"],
      datasets: [{
        data: [customerStats.active, customerStats.locked],
        backgroundColor: ["#28a745", "#dc3545"]
      }]
    },
    options: { plugins: { legend: { position: "bottom" } } }
  });

  new Chart(document.getElementById("chartProvider"), {
    type: "bar",
    data: {
      labels: ["Hoạt động", "Đã khóa", "Chờ duyệt"],
      datasets: [{
        data: [
          providerStats.active,
          providerStats.locked,
          providerStats.pending
        ],
        backgroundColor: ["#28a745", "#dc3545", "#ffc107"]
      }]
    },
    options: {
      scales: { y: { beginAtZero: true } },
      plugins: { legend: { display: false } }
    }
  });
</script>

</body>
</html>
