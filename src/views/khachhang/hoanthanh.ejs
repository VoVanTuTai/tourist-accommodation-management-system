<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-success bg-gradient text-white text-center py-5 border-0">
          <div class="mb-3 animate__animated animate__bounceIn">
            <i class="fas fa-check-circle fa-5x"></i>
          </div>
          <h2 class="fw-bold">Đặt phòng thành công!</h2>
          <p class="mb-0 opacity-75">Cảm ơn bạn đã tin chọn Tourist Management</p>
        </div>

        <div class="card-body p-4 p-md-5">
          <div class="text-center mb-4">
            <h5 class="text-uppercase text-muted small fw-bold tracking-wider">Thông tin đơn hàng</h5>
          </div>
          
          <div class="d-flex justify-content-between align-items-center bg-light p-3 rounded-3 mb-4 border-start border-success border-4">
            <div>
              <span class="text-muted small d-block">Mã đơn hàng:</span>
              <strong class="h5 mb-0 text-dark">#<%= maDon %></strong>
            </div>
            <span class="badge bg-success py-2 px-3 rounded-pill">
              <%= trangThai %>
            </span>
          </div>

          <ul class="list-group list-group-flush mb-4">
            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3 border-bottom">
              <span class="text-muted"><i class="fas fa-money-bill-wave me-2"></i>Tổng tiền thanh toán</span>
              <strong class="text-danger h5 mb-0"><%= Number(tongTien).toLocaleString() %> VND</strong>
            </li>
            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
              <span class="text-muted"><i class="fas fa-calendar-alt me-2"></i>Thời gian xác nhận</span>
              <span><%= new Date().toLocaleDateString('vi-VN') %></span>
            </li>
          </ul>

          <div class="d-grid gap-3 mt-4">
            

            <a href="/" class="btn btn-outline-primary btn-lg rounded-pill fw-bold shadow-sm">
              <i class="fas fa-home me-2"></i>Về trang chủ
            </a>
            
            <div class="text-center mt-2">
              <button class="btn btn-link btn-sm text-decoration-none text-muted" onclick="window.print()">
                <i class="fas fa-print me-2"></i>In thông tin đơn
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .rounded-4 { border-radius: 1.25rem !important; }
  .bg-success.bg-gradient {
    background: linear-gradient(45deg, #198754, #20c997) !important;
  }
  .tracking-wider { letter-spacing: 0.1rem; }
  
  /* Hiệu ứng nút Thanh toán */
  .btn-pay {
    background: linear-gradient(45deg, #ff9800, #f44336);
    border: none;
    color: white !important;
    padding-top: 1rem;
    padding-bottom: 1rem;
    transition: all 0.3s ease;
  }
  
  .btn-pay:hover {
    transform: scale(1.03);
    box-shadow: 0 8px 20px rgba(255, 152, 0, 0.4) !important;
    filter: brightness(1.1);
  }

  /* Nút trang chủ */
  .btn-outline-primary {
    padding-top: 0.8rem;
    padding-bottom: 0.8rem;
  }
</style>