

<div class="container mt-5">
  <h2 class="text-center mb-4 text-success">💳 Thanh Toán Đơn Đặt Phòng</h2>

  <!-- Thông tin đơn hàng -->
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
      <strong>Thông tin đơn đặt phòng</strong>
    </div>
    <div class="card-body">
      <p><strong>Mã đơn:</strong> <%= don.MaDon %></p>
      <p><strong>Nhà cung cấp:</strong> <%= don.TenNCC %></p>
      <p><strong>Ngày nhận:</strong> <%= new Date(don.NgayNhan).toLocaleDateString() %></p>
      <p><strong>Ngày trả:</strong> <%= new Date(don.NgayTra).toLocaleDateString() %></p>
      <p><strong>Tổng tiền:</strong> 
        <span class="fw-bold text-danger"><%= don.TongTien.toLocaleString() %> ₫</span>
      </p>
    </div>
  </div>

  <!-- Thông tin thanh toán -->
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-success text-white">
      <strong>Thông tin thanh toán</strong>
    </div>
    <div class="card-body">
      <% if (don.ThongTinThanhToan) { %>
        <pre class="border p-3 bg-light rounded"><%= don.ThongTinThanhToan %></pre>
      <% } else { %>
        <p class="text-muted">Nhà cung cấp chưa cập nhật thông tin thanh toán.</p>
      <% } %>
    </div>
  </div>

  <!-- Hướng dẫn và hành động -->
  <div class="text-center">
    <p class="mb-3 text-muted">
      Vui lòng kiểm tra kỹ thông tin và số tiền trước khi xác nhận thanh toán.
    </p>

    <form action="/khachhang/don-dat-phong/thanhtoan" method="POST" class="d-inline">
      <input type="hidden" name="MaDon" value="<%= don.MaDon %>">
      <input type="hidden" name="SoTien" value="<%= don.TongTien %>">
      <button type="submit" class="btn btn-success btn-lg">
        💰 Xác nhận thanh toán
      </button>
    </form>

    <a href="/khachhang/don-dat-phong" class="btn btn-secondary btn-lg ms-2">
      ← Quay lại danh sách
    </a>
  </div>
</div>


