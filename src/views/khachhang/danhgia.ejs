<div class="container my-5">
  <div class="card shadow border-0">
    <div class="card-header bg-info text-white text-center">
      <h3 class="mb-0">⭐ Đánh giá đơn #<%= don?.MaDon || '' %></h3>
    </div>

    <div class="card-body p-4">
      <% if (error) { %>
        <div class="alert alert-warning text-center"><%= error %></div>
        <div class="text-center">
          <a href="/khachhang/don-dat-phong" class="btn btn-secondary">⬅ Quay lại</a>
        </div>
      <% } else { %>

        <!-- 🔹 Thông tin đơn -->
        <div class="mb-3">
          <p class="mb-1"><strong>Chỗ ở / NCC:</strong> <%= don?.TenChoO || "Không rõ" %></p>
          <p class="mb-1"><strong>Phòng đã đặt:</strong> <%= don?.DanhSachPhong || "Không rõ" %></p>
          <p class="mb-1"><strong>Thời gian:</strong>
            <%= don?.NgayNhan ? new Date(don.NgayNhan).toLocaleDateString("vi-VN") : "?" %> → 
            <%= don?.NgayTra ? new Date(don.NgayTra).toLocaleDateString("vi-VN") : "?" %>
          </p>
          <p class="mb-0"><strong>Tổng tiền:</strong> <%= (don?.TongTien || 0).toLocaleString("vi-VN") %> ₫</p>
        </div>

        <hr>

        <% if (!daDanhGia || editMode) { %>
          <!-- 📝 Form đánh giá -->
          <form method="POST" enctype="multipart/form-data" class="mx-auto" style="max-width:640px;">

            <!-- 🔸 Chọn phòng cần đánh giá -->
            <div class="mb-3">
              <label class="form-label fw-bold">Chọn phòng để đánh giá</label>
              <select name="MaPhong" id="MaPhong" class="form-select" required>
                <% if (danhSachPhong && danhSachPhong.length > 0) { %>
                  <% danhSachPhong.forEach(phong => { %>
                    <option value="<%= phong.MaPhong %>">
                      <%= phong.TenPhong %> - <%= phong.Gia.toLocaleString("vi-VN") %> ₫
                    </option>
                  <% }) %>
                <% } else { %>
                  <option disabled>Không có phòng nào trong đơn</option>
                <% } %>
              </select>
            </div>

            <!-- 🔸 Số sao -->
            <div class="mb-3 text-center">
              <label class="form-label fw-bold">Số sao</label><br>
              <div id="rating" class="fs-3">
                <% const sao = (danhGia?.SoSao) || 0; %>
                <% for (let i = 1; i <= 5; i++) { %>
                  <i class="bi bi-star-fill star <%= i <= sao ? 'text-warning' : 'text-secondary' %>" 
                    data-value="<%= i %>" style="cursor:pointer;"></i>
                <% } %>
              </div>
              <input type="hidden" name="SoSao" id="SoSao" value="<%= sao %>" required>
            </div>

            <!-- 🔸 Nội dung -->
            <div class="mb-3">
              <label class="form-label fw-bold">Nội dung</label>
              <textarea name="NoiDung" rows="4" class="form-control" required><%= danhGia?.NoiDung || '' %></textarea>
            </div>

            <!-- 🔸 Hình ảnh -->
            <div class="mb-3">
              <label class="form-label fw-bold">Hình ảnh (tùy chọn)</label>
              <input type="file" name="HinhAnh" accept="image/*" class="form-control">
              <% if (danhGia?.HinhAnh) { %>
                <div class="mt-2 text-center">
                  <img src="/uploads/<%= danhGia.HinhAnh %>" class="img-thumbnail" style="max-width:160px;">
                </div>
              <% } %>
            </div>

            <!-- 🔸 Nút hành động -->
            <div class="text-center">
              <button class="btn btn-primary px-4"><%= daDanhGia ? "Cập nhật đánh giá" : "Gửi đánh giá" %></button>
              <a href="/khachhang/don-dat-phong/<%= don.MaDon %>/danhgia" class="btn btn-secondary ms-2">Hủy</a>
            </div>
          </form>
        <% } else { %>
          <!-- ✅ Đã đánh giá -->
          <div class="text-center">
            <div class="fs-4 text-warning mb-2">
              <% for (let i = 1; i <= danhGia.SoSao; i++) { %>
                <i class="bi bi-star-fill"></i>
              <% } %>
            </div>
            <p><strong>Nội dung:</strong> <%= danhGia.NoiDung %></p>
            <% if (danhGia.HinhAnh) { %>
              <img src="/uploads/<%= danhGia.HinhAnh %>" class="img-thumbnail" style="max-width:300px;">
            <% } %>
            <div class="mt-3">
              <a href="/khachhang/don-dat-phong/<%= don.MaDon %>/danhgia?edit=true" class="btn btn-warning">✏️ Sửa đánh giá</a>
              <a href="/khachhang/don-dat-phong" class="btn btn-secondary ms-2">⬅ Quay lại</a>
            </div>
          </div>
        <% } %>

      <% } %>
    </div>
  </div>
</div>

<script>
  // ⭐ Xử lý chọn sao đánh giá
  document.querySelectorAll('.star').forEach(star => {
    star.addEventListener('click', function () {
      const value = Number(this.dataset.value);
      document.getElementById('SoSao').value = value;
      document.querySelectorAll('.star').forEach((s, i) => {
        s.classList.toggle('text-warning', i < value);
        s.classList.toggle('text-secondary', i >= value);
      });
    });
  });
</script>
