<div class="login-container">
  <div class="login-box">
    <h2 class="h3 mb-2 text-capitalize pb-3">Đăng nhập tài khoản</h2>

    <% if (success) { %>
      <div class="success-box">🎉 Đăng ký thành công! Vui lòng đăng nhập.</div>
    <% } %>

    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <form action="/khachhang/dangnhap" method="POST" class="login-form">
      <div class="form-group">
        <label for="Email">Email:</label>
        <input 
          type="email" 
          id="Email" 
          name="Email" 
          placeholder="Nhập email của bạn"
          value="<%= old.Email || '' %>" 
          required
        >
      </div>

      <div class="form-group">
        <label for="MatKhau">Mật khẩu:</label>
        <input 
          type="password" 
          id="MatKhau" 
          name="MatKhau" 
          placeholder="Nhập mật khẩu" 
          required
        >
      </div>

      <div class="form-group remember-me">
        <input type="checkbox" id="rememberMe" name="rememberMe">
        <label for="rememberMe">Ghi nhớ đăng nhập</label>
      </div>

      <div class="form-group submit">
        <button type="submit" class="btn-submit">Đăng nhập</button>
      </div>
    </form>

    <p class="text-center mt-3">
      <a href="/nhacungcap/dangnhap" style="color:#0077b6; text-decoration: underline;">Đăng nhập với tài khoản nhà cung cấp?</a>
    </p>
    <p class="text-center mt-3">
      Chưa có tài khoản? <a href="/khachhang/dangky">Đăng ký ngay</a>
    </p>
  </div>
</div>

<style>
  .login-container {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 40px 20px;
    
    min-height: 80vh;
  }

  .login-box {
    background: #fff;
    padding: 30px 40px;
    border-radius: 12px;
    box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    width: 100%;
    max-width: 420px;
  }

  .login-box h2 {
    text-align: center;
    color: #0077b6;
    margin-bottom: 25px;
  }

  .form-group {
    margin-bottom: 18px;
    display: flex;
    flex-direction: column;
  }

  label {
    font-weight: 500;
    margin-bottom: 5px;
    color: #333;
  }

  input[type="email"], input[type="password"] {
    padding: 8px 10px;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 15px;
    outline: none;
  }

  input:focus {
    border-color: #0077b6;
    box-shadow: 0 0 3px rgba(0,119,182,0.4);
  }

  .remember-me {
    flex-direction: row;
    align-items: center;
    gap: 6px;
  }

  .btn-submit {
    width: 100%;
    background: #0077b6;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 10px;
    font-size: 16px;
    cursor: pointer;
    transition: background 0.2s ease-in-out;
  }

  .btn-submit:hover {
    background: #005f8a;
  }

  .error-box, .success-box {
    padding: 10px 12px;
    border-radius: 6px;
    margin-bottom: 15px;
    text-align: center;
  }

  .error-box {
    background: #ffe6e6;
    border: 1px solid #ffcccc;
    color: #b00020;
  }

  .success-box {
    background: #e8f8e8;
    border: 1px solid #b8e6b8;
    color: #006400;
  }

  .text-center {
    text-align: center;
  }

  a {
    color: #0077b6;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }
</style>
