<%- include("../partials/timkiem") %>

<div class="container mt-4">
    <h3 class="text-center mb-3">Kết quả tìm kiếm phòng</h3>

    <% if (message) { %>
    <div class="alert alert-warning text-center"><%= message %></div>
    <% } %> <% if (phongList && phongList.length > 0) { %> <% if (query.giaMin
    || query.giaMax) { %>
    <p class="text-muted text-center">
        Kết quả cho phòng có giá từ <%= parseInt(query.giaMin ||
        0).toLocaleString() %> ₫ đến <%= parseInt(query.giaMax ||
        0).toLocaleString() %> ₫
    </p>
    <% } %>

    <div class="row">
        <% phongList.forEach(phong => { %>
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <img
                    src="<%= phong.HinhAnh ? '/images/' + phong.HinhAnh : '/public/images/no-image.jpg' %>"
                    class="card-img-top"
                    alt="Ảnh phòng"
                    style="height: 220px; object-fit: cover"
                />

                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><%= phong.TenPhong %></h5>
                    <p class="card-text mb-2">
                        <strong>Loại:</strong> <%= phong.TenLoai %><br />
                        <strong>Địa điểm:</strong> <%= phong.TenXa %>, <%=
                        phong.TenTinh %><br />
                        <strong>Giá:</strong> <%= phong.Gia.toLocaleString() %>
                        ₫ / đêm<br />
                        <strong>Đánh giá:</strong> ⭐ <%= phong.DanhGia ?
                        phong.DanhGia.toFixed(1) : 'Chưa có' %>
                    </p>
                    <a
                        href="/phong/chi-tiet/<%= phong.MaPhong %>"
                        class="btn w-100 **custom-gradient-btn**"
                    >
                        Xem chi tiết
                    </a>
                </div>
            </div>
        </div>
        <% }) %>
    </div>

    <% } else { %>
    <div class="alert alert-info text-center">
        Không có phòng nào để hiển thị.
    </div>
    <% } %>
</div>
