<div class="container py-4">
    <% if (success && success.length > 0) { %>
        <script>
          Swal.fire({
            icon: 'success',
            title: 'Thành công!',
            text: '<%= success %>',
            timer: 2200,
            showConfirmButton: false
          });
        </script>
      <% } %>
      

    <div class="main-container fade-in">
        <h2 class="page-title">Danh sách đơn đặt phòng</h2>
        <!-- 🔹 Thanh tab trạng thái -->
        <ul class="nav nav-tabs status-tabs justify-content-center">
            <li class="nav-item">
                <a
                    class="nav-link <%= !trangThai ? 'active' : '' %>"
                    href="/khachhang/don-dat-phong"
                >
                    <i class="bi bi-list-ul me-2"></i>Tất cả
                </a>
            </li>
            <li class="nav-item">
                <a
                    class="nav-link <%= trangThai == 0 ? 'active' : '' %>"
                    href="/khachhang/don-dat-phong?trangthai=0"
                >
                    <i class="bi bi-bookmark-check me-2"></i>Đã đặt
                </a>
            </li>
            <li class="nav-item">
                <a
                    class="nav-link <%= trangThai == 1 ? 'active' : '' %>"
                    href="/khachhang/don-dat-phong?trangthai=1"
                >
                    <i class="bi bi-clock me-2"></i>Đang sử dụng
                </a>
            </li>
            <li class="nav-item">
                <a
                    class="nav-link <%= trangThai == 2 ? 'active' : '' %>"
                    href="/khachhang/don-dat-phong?trangthai=2"
                >
                    <i class="bi bi-check-circle me-2"></i>Hoàn tất
                </a>
            </li>
            <li class="nav-item">
                <a
                    class="nav-link <%= trangThai == 3 ? 'active' : '' %>"
                    href="/khachhang/don-dat-phong?trangthai=3"
                >
                    <i class="bi bi-x-circle me-2"></i>Đã hủy
                </a>
            </li>
        </ul>

        <!-- 🔹 Bảng danh sách đơn -->
        <div class="table-container">
            <div class="table-scroll">
                <table class="table text-center align-middle mb-0">
                    <thead>
                        <tr>
                            <th><i class="bi bi-hash me-2"></i>Mã đơn</th>
                            <th>
                                <i class="bi bi-building me-2"></i>Tên nhà cung cấp
                                (chỗ ở)
                            </th>
                            <th>
                                <i class="bi bi-calendar-plus me-2"></i>Ngày đặt
                            </th>
                            <th>
                                <i class="bi bi-calendar-check me-2"></i>Ngày nhận
                            </th>
                            <th><i class="bi bi-calendar-x me-2"></i>Ngày trả</th>
                            <th>
                                <i class="bi bi-currency-dollar me-2"></i>Tổng tiền
                            </th>
                            <th><i class="bi bi-flag me-2"></i>Trạng thái</th>
                            <th><i class="bi bi-gear me-2"></i>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (donDatPhongList.length > 0) { %> <%
                        donDatPhongList.forEach((don) => { %>
                        <tr>
                            <td class="order-id">#<%= don.MaDon %></td>

                            <td><%= don.TenChoO || "Chưa rõ" %></td>

                            <td>
                                <%= don.NgayDat ? new
                                Date(don.NgayDat).toLocaleDateString("vi-VN") : "-"
                                %>
                            </td>
                            <td>
                                <%= don.NgayNhan ? new
                                Date(don.NgayNhan).toLocaleDateString("vi-VN") : "-"
                                %>
                            </td>
                            <td>
                                <%= don.NgayTra ? new
                                Date(don.NgayTra).toLocaleDateString("vi-VN") : "-"
                                %>
                            </td>

                            <td class="price">
                                <%= don.TongTien ?
                                don.TongTien.toLocaleString("vi-VN") : 0 %> ₫
                            </td>

                            <td>
                                <% if (don.TrangThai == 0) { %>
                                <span class="badge bg-primary status-badge"
                                    >Đã đặt</span
                                >
                                <% } else if (don.TrangThai == 1) { %>
                                <span
                                    class="badge bg-warning text-dark status-badge"
                                    >Đang sử dụng</span
                                >
                                <% } else if (don.TrangThai == 2) { %>
                                <span class="badge bg-success status-badge"
                                    >Hoàn tất</span
                                >
                                <% } else if (don.TrangThai == 3) { %>
                                <span class="badge bg-danger status-badge"
                                    >Đã hủy</span
                                >
                                <% } %>
                            </td>

                            <td>
                                <button
                                    class="action-btn btn-info"
                                    onclick="location.href='/khachhang/don-dat-phong/<%= don.MaDon %>'"
                                >
                                    Chi tiết
                                </button>
                            </td>
                        </tr>
                        <% }); %> <% } else { %>
                        <tr>
                            <td colspan="8" class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <h4>Không có đơn đặt phòng nào</h4>
                                <p>
                                    Chưa có đơn đặt phòng nào phù hợp với bộ lọc
                                    hiện tại.
                                </p>
                            </td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
