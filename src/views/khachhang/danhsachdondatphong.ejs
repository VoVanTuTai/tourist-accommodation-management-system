<div class="container mt-4">
  <h2 class="text-center mb-4">Danh sách đơn đặt phòng</h2>

  <!-- 🔹 Navbar trạng thái -->
  <ul class="nav nav-tabs justify-content-center mb-4">
    <li class="nav-item">
      <a class="nav-link <%= !trangThai ? 'active' : '' %>" href="/khachhang/don-dat-phong">Tất cả</a>
    </li>
    <li class="nav-item">
      <a class="nav-link <%= trangThai == 0 ? 'active' : '' %>" href="/khachhang/don-dat-phong?trangthai=0">Đã đặt</a>
    </li>
    <li class="nav-item">
      <a class="nav-link <%= trangThai == 1 ? 'active' : '' %>" href="/khachhang/don-dat-phong?trangthai=1">Đang sử dụng</a>
    </li>
    <li class="nav-item">
      <a class="nav-link <%= trangThai == 2 ? 'active' : '' %>" href="/khachhang/don-dat-phong?trangthai=2">Hoàn tất</a>
    </li>
    <li class="nav-item">
      <a class="nav-link <%= trangThai == 3 ? 'active' : '' %>" href="/khachhang/don-dat-phong?trangthai=3">Đã hủy</a>
    </li>
  </ul>

  <!-- 🔹 Bảng danh sách -->
  <table class="table table-striped text-center align-middle">
    <thead class="table-dark">
      <tr>
        <th>Mã đơn</th>
        <th>Tên nhà cung cấp (chỗ ở)</th>
        <th>Ngày đặt</th>
        <th>Ngày nhận</th>
        <th>Ngày trả</th>
        <th>Tổng tiền</th>
        <th>Trạng thái</th>
        <th>Hành động</th>
      </tr>
    </thead>
    <tbody>
      <% if (donDatPhongList.length > 0) { %>
        <% donDatPhongList.forEach((don) => { %>
          <tr>
            <td><%= don.MaDon %></td>
            <td><%= don.TenNCC || "Chưa rõ" %></td>
            <td><%= don.NgayDat ? new Date(don.NgayDat).toLocaleDateString("vi-VN") : "-" %></td>
            <td><%= don.NgayNhan ? new Date(don.NgayNhan).toLocaleDateString("vi-VN") : "-" %></td>
            <td><%= don.NgayTra ? new Date(don.NgayTra).toLocaleDateString("vi-VN") : "-" %></td>
            <td><%= don.TongTien ? don.TongTien.toLocaleString("vi-VN") : 0 %> ₫</td>
            <td>
              <% if (don.TrangThai == 0) { %>
                <span class="badge bg-primary">Đã đặt</span>
              <% } else if (don.TrangThai == 1) { %>
                <span class="badge bg-warning text-dark">Đang sử dụng</span>
              <% } else if (don.TrangThai == 2) { %>
                <span class="badge bg-success">Hoàn tất</span>
              <% } else if (don.TrangThai == 3) { %>
                <span class="badge bg-danger">Đã hủy</span>
              <% } %>
            </td>
            <td>
              <a href="/khachhang/don-dat-phong/<%= don.MaDon %>" class="btn btn-info btn-sm">Chi tiết</a>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="8" class="text-muted py-4">Không có đơn đặt phòng nào.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
