<div class="booking-page-wrapper py-5" style="background-color: #f0f2f5;">
  <div class="container">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger shadow-sm border-0 rounded-3 mb-4">
        <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
      </div>
    <% } %>

    <div class="row g-4">
      <div class="col-lg-8">
        <form action="/khachhang/dat-phong/preview" method="POST" class="needs-validation" id="bookingForm">
          <input type="hidden" name="MaPhong" value="<%= (room && room.MaPhong) ? room.MaPhong : '' %>">

          <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
              <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-calendar-alt me-2"></i>Thời gian lưu trú</h5>
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label small fw-bold">Ngày nhận phòng</label>
                  <input type="date" name="NgayNhan" id="NgayNhan" 
                         value="<%= (typeof form !== 'undefined' && form.NgayNhan) ? form.NgayNhan : new Date().toISOString().split('T')[0] %>" 
                         min="<%= new Date().toISOString().split('T')[0] %>"
                         class="form-control form-control-lg border-2" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label small fw-bold">Ngày trả phòng</label>
                  <input type="date" name="NgayTra" id="NgayTra" 
                         value="<%= (typeof form !== 'undefined' && form.NgayTra) ? form.NgayTra : '' %>" 
                         class="form-control form-control-lg border-2" required>
                </div>
              </div>
            </div>
          </div>

          <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
              <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-user-edit me-2"></i>Thông tin người đặt</h5>
              <div class="row g-3">
                <div class="col-md-12 mb-3">
                  <label class="form-label">Họ và tên người đặt</label>
                  <input type="text" name="Dat_HoTen" id="Dat_HoTen" class="form-control" 
                         value="<%= (user && user.HoTen) ? user.HoTen : '' %>" required>
                </div>
                <div class="col-md-6 mb-3">
                  <label class="form-label">Số điện thoại</label>
                  <input type="tel" name="Dat_SDT" id="Dat_SDT" class="form-control" 
                         value="<%= (user && user.SoDienThoai) ? user.SoDienThoai : '' %>" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label small fw-bold">Số CCCD/CMND</label>
                  <input type="text" name="Dat_CCCD" id="Dat_CCCD" class="form-control border-2" required>
                </div>
              </div>
              <div class="form-check mt-4 p-3 bg-light rounded-3">
                <input type="checkbox" id="samePerson" class="form-check-input ms-0 me-2">
                <label class="form-check-label fw-bold text-dark" for="samePerson" style="cursor:pointer">Tôi là người sẽ nhận phòng</label>
              </div>
            </div>
          </div>

          <div class="card shadow-sm border-0 rounded-4 mb-4" id="receiverSection">
            <div class="card-body p-4">
              <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-user-check me-2"></i>Thông tin người nhận phòng</h5>
              <div class="row g-3">
                <div class="col-md-12">
                  <input type="text" name="Nhan_HoTen" class="form-control border-2" placeholder="Họ và tên người nhận" required>
                </div>
                <div class="col-md-6">
                  <input type="tel" name="Nhan_SDT" class="form-control border-2" placeholder="Số điện thoại người nhận" required>
                </div>
                <div class="col-md-6">
                  <input type="text" name="Nhan_CCCD" class="form-control border-2" placeholder="CCCD người nhận" required>
                </div>
              </div>
            </div>
          </div>

          <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill py-3 fw-bold shadow">
            TIẾP TỤC XÁC NHẬN <i class="fas fa-arrow-right ms-2"></i>
          </button>
        </form>
      </div>

      <div class="col-lg-4">
        <div class="sticky-top" style="top: 100px;">
          <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <% 
              let displayImage = 'unnamed.jpg'; 
              if (room && room.HinhAnh) {
                // Xử lý chuỗi HinhAnh bị lỗi format trong DB của bạn
                let cleanPath = room.HinhAnh.replace(/[\[\]\"\\ ]/g, ''); 
                displayImage = cleanPath.split(',')[0] || 'unnamed.jpg';
              }
            %>
            <img src="/images/<%= displayImage %>" class="card-img-top" 
                 style="height: 250px; object-fit: cover; background-color: #eee;" 
                 onerror="this.src='/images/unnamed.jpg'">
            
            <div class="card-body p-4">
              <span class="badge bg-info text-dark mb-2">Phòng chất lượng cao</span>
              <h4 class="fw-bold mb-1"><%= room?.TenPhong || 'Thông tin phòng' %></h4>
              <p class="text-muted small mb-3"><i class="fas fa-map-marker-alt me-1"></i> Đà Nẵng</p>
              
              <hr class="my-3 opacity-10">
              
              <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Giá mỗi đêm:</span>
                <span class="fw-bold text-primary"><%= room?.Gia ? room.Gia.toLocaleString('vi-VN') : 0 %> VND</span>
              </div>
              <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Số đêm lưu trú:</span>
                <span class="fw-bold" id="nightCount">0 đêm</span>
              </div>
              
              <div class="bg-light p-3 rounded-3 mt-4 border border-primary border-opacity-10">
                <div class="d-flex justify-content-between align-items-center">
                  <span class="fw-bold">Tạm tính:</span>
                  <span class="h5 fw-bold text-danger mb-0" id="tempTotal">0 VND</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const ngayNhanInput = document.getElementById('NgayNhan');
    const ngayTraInput = document.getElementById('NgayTra');
    const tempTotal = document.getElementById('tempTotal');
    const nightCount = document.getElementById('nightCount');
    
    // Lấy giá phòng sạch
    const rawGia = "<%= room?.Gia %>";
    const giaPhong = parseInt(rawGia.replace(/\D/g, '')) || 0;

    function calculateTotal() {
      if (!ngayNhanInput.value || !ngayTraInput.value) return;

      const start = new Date(ngayNhanInput.value);
      const end = new Date(ngayTraInput.value);
      
      if (end > start) {
        const diffDays = Math.ceil(Math.abs(end - start) / (1000 * 60 * 60 * 24));
        nightCount.innerText = diffDays + " đêm";
        tempTotal.innerText = (diffDays * giaPhong).toLocaleString('vi-VN') + " VND";
      } else {
        nightCount.innerText = "0 đêm";
        tempTotal.innerText = "0 VND";
      }
    }

    ngayNhanInput.addEventListener('change', calculateTotal);
    ngayTraInput.addEventListener('change', calculateTotal);

    document.getElementById("samePerson").addEventListener("change", function() {
      const isChecked = this.checked;
      const fields = {
        'Nhan_HoTen': document.getElementById("Dat_HoTen").value,
        'Nhan_SDT': document.getElementById("Dat_SDT").value,
        'Nhan_CCCD': document.getElementById("Dat_CCCD").value
      };
      
      for (let key in fields) {
        const input = document.querySelector(`input[name="${key}"]`);
        if (input) input.value = isChecked ? fields[key] : "";
      }
      document.getElementById("receiverSection").style.opacity = isChecked ? "0.7" : "1";
    });

    calculateTotal();
  });
</script>