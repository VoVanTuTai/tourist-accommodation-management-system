<div class="booking-container py-5">
  <div class="booking-card shadow-lg rounded-4 p-4">
    <% if (error) { %>
      <div class="alert alert-danger text-center mb-4">
        <%= error %>
      </div>
      <% } %>

        <% if (room) { %>
          <div class="text-center mb-4">
            <h2 class="fw-bold text-gradient mb-2">
              <%= room.TenPhong %>
            </h2>
            <p class="text-muted mb-1">
              💰 <strong>
                <%= room.Gia.toLocaleString() %> VND/đêm
              </strong> |
              👤 Sức chứa: <%= room.SucChua %> người
            </p>
          </div>

          <form action="/khachhang/dat-phong/preview" method="POST" class="needs-validation" novalidate>
            <input type="hidden" name="MaPhong" value="<%= room.MaPhong %>">

            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">Ngày nhận phòng</label>
                <input type="date" name="NgayNhan" value="<%= form.NgayNhan %>" class="form-control" required>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Ngày trả phòng</label>
                <input type="date" name="NgayTra" value="<%= form.NgayTra %>" class="form-control" required>
              </div>
            </div>

            <hr class="my-4">

            <h5 class="fw-bold text-primary mb-3"><i class="fas fa-user"></i> Thông tin người đặt phòng</h5>
            <div class="row g-3">
              <div class="col-md-6">
                <input class="form-control" name="Dat_HoTen" placeholder="Họ và tên" required>
              </div>
              <div class="col-md-6">
                <input class="form-control" name="Dat_SDT" placeholder="Số điện thoại" required>
              </div>
              <div class="col-md-6">
                <input class="form-control" name="Dat_CCCD" placeholder="CCCD/CMND" required>
              </div>
              <div class="col-md-6">
                <input class="form-control" type="date" name="Dat_NgaySinh" required>
              </div>
              <div class="col-md-6">
                <select class="form-select" name="Dat_GioiTinh" required>
                  <option value="">-- Giới tính --</option>
                  <option value="Nam">Nam</option>
                  <option value="Nữ">Nữ</option>
                </select>
              </div>
            </div>

            <div class="form-check mt-4">
              <input type="checkbox" id="samePerson" class="form-check-input">
              <label class="form-check-label fw-semibold" for="samePerson">
                Đặt phòng cho chính tôi
              </label>
            </div>

            <hr class="my-4">

            <h5 class="fw-bold text-primary mb-3"><i class="fas fa-bed"></i> Thông tin người nhận phòng</h5>
            <div class="row g-3">
              <div class="col-md-6">
                <input class="form-control" name="Nhan_HoTen" placeholder="Họ và tên" required>
              </div>
              <div class="col-md-6">
                <input class="form-control" name="Nhan_SDT" placeholder="Số điện thoại" required>
              </div>
              <div class="col-md-6">
                <input class="form-control" name="Nhan_CCCD" placeholder="CCCD/CMND" required>
              </div>
              <div class="col-md-6">
                <input class="form-control" type="date" name="Nhan_NgaySinh" required>
              </div>
              <div class="col-md-6">
                <select class="form-select" name="Nhan_GioiTinh" required>
                  <option value="">-- Giới tính --</option>
                  <option value="Nam">Nam</option>
                  <option value="Nữ">Nữ</option>
                </select>
              </div>
            </div>

            <div class="text-center mt-5">
              <button type="submit" class="btn-submit">
                <i class="fas fa-check-circle me-2"></i>Hoàn tất đặt phòng
              </button>
            </div>
          </form>
          <% } %>
  </div>
</div>

<script>
  document.getElementById("samePerson").addEventListener("change",function() {
    const fields=["HoTen","SDT","CCCD","NgaySinh","GioiTinh"];
    if(this.checked) {
      fields.forEach(f => {
        document.querySelector(`[name='Nhan_${f}']`).value=document.querySelector(`[name='Dat_${f}']`).value;
      });
    } else {
      fields.forEach(f => document.querySelector(`[name='Nhan_${f}']`).value="");
    }
  });
</script>

<style>
  .booking-container {
    background: linear-gradient(180deg, #f4f1ff 0%, #e8e8ff 100%);
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .booking-card {
    background: #fff;
    width: 100%;
    max-width: 850px;
    margin-top: 40px;
    border: none;
  }

  .text-gradient {
    background: linear-gradient(90deg, #5b46f0, #b54cf5);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .form-control,
  .form-select {
    border-radius: 10px;
    border: 1px solid #d0d0ff;
    box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.05);
    padding: 10px 12px;
  }

  .form-control:focus,
  .form-select:focus {
    border-color: #6c63ff;
    box-shadow: 0 0 4px rgba(108, 99, 255, 0.4);
  }

  .btn-submit {
    background: linear-gradient(90deg, #6c63ff, #4f46e5);
    color: #fff;
    border: none;
    border-radius: 30px;
    padding: 12px 30px;
    font-weight: 600;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 10px rgba(108, 99, 255, 0.3);
    transition: all 0.3s ease;
  }

  .btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 14px rgba(108, 99, 255, 0.45);
  }
</style>