<div class="booking-page-wrapper py-5" style="background-color: #f0f2f5;">
  <div class="container">
    <% if (error) { %>
      <div class="alert alert-danger shadow-sm border-0 rounded-3 mb-4">
        <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
      </div>
    <% } %>

    <div class="row g-4">
      <div class="col-lg-8">
        <form action="/khachhang/dat-phong/preview" method="POST" class="needs-validation" id="bookingForm">

      <input type="hidden" name="MaPhong" value="<%= (room && room.MaPhong) ? room.MaPhong : '' %>">
          <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
              <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-calendar-alt me-2"></i>Thời gian lưu trú</h5>
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label small fw-bold">Ngày nhận phòng</label>
                  <input type="date" name="NgayNhan" value="<%= form.NgayNhan %>" class="form-control form-control-lg border-2" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label small fw-bold">Ngày trả phòng</label>
                  <input type="date" name="NgayTra" value="<%= form.NgayTra %>" class="form-control form-control-lg border-2" required>
                </div>
              </div>
            </div>
          </div>

          <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
              <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-user-edit me-2"></i>Thông tin người đặt</h5>
              <div class="row g-3">
                <div class="col-md-12">
                  <input type="text" name="Dat_HoTen" class="form-control border-2" placeholder="Họ và tên người đặt" required>
                </div>
                <div class="col-md-6">
                  <input type="tel" name="Dat_SDT" class="form-control border-2" placeholder="Số điện thoại" required>
                </div>
                <div class="col-md-6">
                  <input type="text" name="Dat_CCCD" class="form-control border-2" placeholder="Số CCCD/CMND" required>
                </div>
              </div>
              <div class="form-check mt-4 p-3 bg-light rounded-3">
                <input type="checkbox" id="samePerson" class="form-check-input ms-0 me-2">
                <label class="form-check-label fw-bold text-dark" for="samePerson">
                  Tôi là người sẽ nhận phòng
                </label>
              </div>
            </div>
          </div>

          <div class="card shadow-sm border-0 rounded-4 mb-4" id="receiverSection">
            <div class="card-body p-4">
              <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-user-check me-2"></i>Thông tin người nhận phòng</h5>
              <div class="row g-3">
                <div class="col-md-12">
                  <input type="text" name="Nhan_HoTen" class="form-control border-2" placeholder="Họ và tên người nhận" required>
                </div>
                <div class="col-md-6">
                  <input type="tel" name="Nhan_SDT" class="form-control border-2" placeholder="Số điện thoại người nhận" required>
                </div>
                <div class="col-md-6">
                  <input type="text" name="Nhan_CCCD" class="form-control border-2" placeholder="CCCD người nhận" required>
                </div>
              </div>
            </div>
          </div>

          <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill py-3 fw-bold shadow">
            TIẾP TỤC XÁC NHẬN <i class="fas fa-arrow-right ms-2"></i>
          </button>
        </form>
      </div>

      <div class="col-lg-4">
        <div class="sticky-top" style="top: 100px;">
          <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <img src="/img/<%= room?.HinhAnh || 'default.jpg' %>" class="card-img-top" style="height: 200px; object-fit: cover;">
            <div class="card-body p-4">
              <span class="badge bg-soft-primary text-primary mb-2">Phòng chất lượng cao</span>
              <h4 class="fw-bold mb-1"><%= room?.TenPhong || 'Thông tin phòng' %></h4>
              <p class="text-muted small mb-3"><i class="fas fa-map-marker-alt me-1"></i> <%= room.TenTinh %></p>
              
              <hr class="my-3 opacity-10">
              
              <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Giá mỗi đêm:</span>
                <span class="fw-bold"><%= room?.Gia ? room.Gia.toLocaleString() : 0 %> VND</span>
              </div>
              <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Sức chứa:</span>
                <span class="fw-bold"><%= room.SucChua %> người</span>
              </div>
              
              <div class="bg-light p-3 rounded-3 mt-4">
                <div class="d-flex justify-content-between align-items-center">
                  <span class="fw-bold">Tổng thanh toán:</span>
                  <span class="h5 fw-bold text-danger mb-0" id="tempTotal"><%= room.Gia.toLocaleString() %> VND</span>
                </div>
                <small class="text-muted text-end d-block mt-1">Tính cho 1 đêm</small>
              </div>
            </div>
          </div>
          
          <div class="mt-3 p-3 text-center border rounded-4 bg-white">
            <p class="small text-muted mb-0"><i class="fas fa-shield-alt text-success me-1"></i> Thanh toán an toàn và bảo mật</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .form-control {
    padding: 12px 15px;
    font-size: 0.95rem;
    transition: all 0.2s;
  }
  .form-control:focus {
    box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    border-color: #0d6efd;
  }
  .card { transition: transform 0.2s; }
  .bg-soft-primary { background-color: #e7f1ff; }
  .btn-primary {
    background: linear-gradient(90deg, #4e54c8, #8f94fb);
    border: none;
  }
  .btn-primary:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }
  hr { border-top: 2px solid #eee; }
</style>

<script>
  // Logic tự động điền thông tin người nhận
  document.getElementById("samePerson").addEventListener("change", function() {
    const isChecked = this.checked;
    const datTen = document.querySelector('input[name="Dat_HoTen"]').value;
    const datSDT = document.querySelector('input[name="Dat_SDT"]').value;
    const datCCCD = document.querySelector('input[name="Dat_CCCD"]').value;

    if (isChecked) {
      document.querySelector('input[name="Nhan_HoTen"]').value = datTen;
      document.querySelector('input[name="Nhan_SDT"]').value = datSDT;
      document.querySelector('input[name="Nhan_CCCD"]').value = datCCCD;
      // Ẩn bớt phần người nhận để gọn hơn nếu muốn
      // document.getElementById("receiverSection").style.opacity = "0.6";
    } else {
      document.querySelector('input[name="Nhan_HoTen"]').value = "";
      document.querySelector('input[name="Nhan_SDT"]').value = "";
      document.querySelector('input[name="Nhan_CCCD"]').value = "";
    }
  });
</script>