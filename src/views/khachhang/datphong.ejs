<div class="booking-page-wrapper py-5" style="background-color: #f0f2f5;">
  <div class="container">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger shadow-sm border-0 rounded-3 mb-4">
        <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
      </div>
    <% } %>

    <div class="row g-4">
      <div class="col-lg-8">
        <form action="/khachhang/dat-phong/preview" method="POST" id="bookingForm" novalidate>
          <input type="hidden" name="MaPhong" value="<%= (room && room.MaPhong) ? room.MaPhong : '' %>">

          <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
              <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-calendar-alt me-2"></i>Thời gian lưu trú tạm tính</h5>
              <div class="row g-3">
                <% 
                  let now = new Date();
                  let offset = now.getTimezoneOffset() * 60000;
                  let todayStr = (new Date(now - offset)).toISOString().split('T')[0];
                  let tomorrow = new Date(now.getTime() + (24 * 60 * 60 * 1000) - offset);
                  let tomorrowStr = tomorrow.toISOString().split('T')[0];
                  let valNgayNhan = (typeof form !== 'undefined' && form.NgayNhan) ? form.NgayNhan : todayStr;
                  let valNgayTra = (typeof form !== 'undefined' && form.NgayTra) ? form.NgayTra : tomorrowStr;
                %>
                <div class="col-md-6">
                  <label class="form-label small fw-bold">Ngày nhận phòng</label>
                  <input type="date" name="NgayNhan" id="NgayNhan" value="<%= valNgayNhan %>" min="<%= todayStr %>" class="form-control form-control-lg border-2" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label small fw-bold">Ngày trả phòng</label>
                  <input type="date" name="NgayTra" id="NgayTra" value="<%= valNgayTra %>" min="<%= tomorrowStr %>" class="form-control form-control-lg border-2" required>
                </div>
              </div>
            </div>
          </div>

          <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
              <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-user-edit me-2"></i>Thông tin người đặt</h5>
              <div class="row g-3">
                <div class="col-md-12 mb-3">
                  <label class="form-label fw-bold">Họ và tên người đặt</label>
                  <input type="text" name="Dat_HoTen" id="Dat_HoTen" class="form-control border-2" 
                         value="<%= (user && user.HoTen) ? user.HoTen : '' %>" required placeholder="Nhập đầy đủ họ và tên">
                  <div class="invalid-feedback">Họ tên chỉ chứa chữ cái Tiếng Việt và ít nhất 2 từ.</div>
                </div>
                <div class="col-md-6 mb-3">
                  <label class="form-label fw-bold">Số điện thoại</label>
                  <input type="tel" name="Dat_SDT" id="Dat_SDT" class="form-control border-2" 
                         value="<%= (user && user.SoDienThoai) ? user.SoDienThoai : '' %>" required placeholder="VD: 0369123456">
                  <div class="invalid-feedback">SĐT phải có 10 số và bắt đầu bằng số 0.</div>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold">Số CCCD/CMND</label>
                  <input type="text" name="Dat_CCCD" id="Dat_CCCD" class="form-control border-2" required placeholder="Nhập 9 hoặc 12 chữ số">
                  <div class="invalid-feedback">CCCD phải gồm 9 hoặc 12 chữ số.</div>
                </div>
              </div>
              <div class="form-check mt-4 p-3 bg-light rounded-3">
                <input type="checkbox" id="samePerson" class="form-check-input ms-0 me-2">
                <label class="form-check-label fw-bold text-dark" for="samePerson" style="cursor:pointer">Tôi là người sẽ nhận phòng</label>
              </div>
            </div>
          </div>

          <div class="card shadow-sm border-0 rounded-4 mb-4" id="receiverSection">
            <div class="card-body p-4">
              <h5 class="fw-bold mb-4 text-primary"><i class="fas fa-user-check me-2"></i>Thông tin người nhận phòng</h5>
              <div class="row g-3">
                <div class="col-md-12 mb-3">
                  <label class="form-label fw-bold small">Họ và tên người nhận</label>
                  <input type="text" name="Nhan_HoTen" id="Nhan_HoTen" class="form-control border-2" placeholder="Ví dụ: Hứa Minh Khương" required>
                  <div class="invalid-feedback">Họ tên chỉ chứa chữ cái Tiếng Việt.</div>
                </div>
                <div class="col-md-6 mb-3">
                  <label class="form-label fw-bold small">SĐT người nhận</label>
                  <input type="tel" name="Nhan_SDT" id="Nhan_SDT" class="form-control border-2" placeholder="VD: 0905123456" required>
                  <div class="invalid-feedback">SĐT người nhận không hợp lệ (10 số, bắt đầu bằng 0).</div>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold small">CCCD người nhận</label>
                  <input type="text" name="Nhan_CCCD" id="Nhan_CCCD" class="form-control border-2" placeholder="Nhập 9 hoặc 12 số" required>
                  <div class="invalid-feedback">CCCD người nhận không hợp lệ.</div>
                </div>
              </div>
            </div>
          </div>

          <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill py-3 fw-bold shadow" id="btnSubmit">
            TIẾP TỤC XÁC NHẬN <i class="fas fa-arrow-right ms-2"></i>
          </button>
        </form>
      </div>

      <div class="col-lg-4">
        <div class="sticky-top" style="top: 100px;">
          <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <% 
              let displayImage = 'unnamed.jpg'; 
              try {
                if (room && room.HinhAnh) {
                  // Xử lý dữ liệu HinhAnh từ DB (JSON array)
                  let rawImg = room.HinhAnh;
                  if (typeof rawImg === 'string' && rawImg.startsWith('[')) {
                    let imgArray = JSON.parse(rawImg);
                    displayImage = imgArray[0];
                  } else {
                    displayImage = rawImg.replace(/[\[\]\"\\ ]/g, '').split(',')[0];
                  }
                }
              } catch (e) { displayImage = 'unnamed.jpg'; }
            %>
            <img src="/images/<%= displayImage %>" class="card-img-top" style="height: 250px; object-fit: cover;" onerror="this.src='/images/unnamed.jpg'">
            
            <div class="card-body p-4">
              <h4 class="fw-bold mb-1"><%= room?.TenPhong || 'Thông tin phòng' %></h4>
              <hr class="my-3 opacity-10">
              <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Giá mỗi đêm:</span>
                <span class="fw-bold text-primary"><%= room?.Gia ? room.Gia.toLocaleString('vi-VN') : 0 %> VND</span>
              </div>
              <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Số đêm:</span>
                <span class="fw-bold" id="nightCount">0 đêm</span>
              </div>
              <div class="bg-light p-3 rounded-3 mt-4 border border-primary border-opacity-10">
                <div class="d-flex justify-content-between align-items-center">
                  <span class="fw-bold">Tạm tính:</span>
                  <span class="h5 fw-bold text-danger mb-0" id="tempTotal">0 VND</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .invalid-feedback { display: none; width: 100%; margin-top: 0.25rem; font-size: 0.875em; color: #dc3545; }
  .is-invalid ~ .invalid-feedback { display: block; }
  .is-invalid { border-color: #dc3545 !important; }
  .is-valid { border-color: #198754 !important; }
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const bookingForm = document.getElementById("bookingForm");

  /* ================= GIÁ PHÒNG ================= */
  const giaPhong = parseInt("<%= room?.Gia %>".replace(/\D/g, '')) || 0;

  const ngayNhanInput = document.getElementById('NgayNhan');
  const ngayTraInput = document.getElementById('NgayTra');
  const nightCountText = document.getElementById('nightCount');
  const tempTotalText = document.getElementById('tempTotal');

  function updatePrice() {
    const start = new Date(ngayNhanInput.value);
    const end = new Date(ngayTraInput.value);

    if (ngayNhanInput.value && ngayTraInput.value && end > start) {
      const diffDays = Math.ceil((end - start) / (1000 * 60 * 60 * 24));
      nightCountText.innerText = diffDays + " đêm";
      tempTotalText.innerText =
        (diffDays * giaPhong).toLocaleString('vi-VN') + " VND";
    } else {
      nightCountText.innerText = "0 đêm";
      tempTotalText.innerText = "0 VND";
    }
  }

  ngayNhanInput.addEventListener('change', updatePrice);
  ngayTraInput.addEventListener('change', updatePrice);
  updatePrice();

  /* ================= REGEX CHUẨN ================= */
  // \p{L} = tất cả chữ cái Unicode (bao gồm Tiếng Việt)
  const namePattern = /^[\p{L}\s]+$/u;
  const phonePattern = /^0\d{9}$/;
  const cccdPattern = /^\d{9}$|^\d{12}$/;

  function validateInput(input) {
    const value = input.value.trim();
    let isValid = true;

    if (input.id === "Dat_HoTen") {
      // Người đặt: >= 2 từ
      isValid =
        namePattern.test(value) &&
        value.split(/\s+/).filter(w => w !== "").length >= 2;
    }
    else if (input.id === "Nhan_HoTen") {
      // Người nhận: chỉ cần chữ
      isValid = namePattern.test(value);
    }
    else if (input.id.includes("SDT")) {
      isValid = phonePattern.test(value);
    }
    else if (input.id.includes("CCCD")) {
      isValid = cccdPattern.test(value);
    }

    if (!isValid && value !== "") {
      input.classList.add("is-invalid");
      input.classList.remove("is-valid");
    } else if (isValid && value !== "") {
      input.classList.remove("is-invalid");
      input.classList.add("is-valid");
    } else {
      input.classList.remove("is-invalid", "is-valid");
    }

    return isValid;
  }

  const allInputs = bookingForm.querySelectorAll("input[required]");
  allInputs.forEach(input => {
    input.addEventListener("input", () => validateInput(input));
    input.addEventListener("blur", () => validateInput(input));
  });

  /* ================= CHECKBOX ================= */
  document.getElementById("samePerson").addEventListener("change", function () {
    const fields = [
      { from: "Dat_HoTen", to: "Nhan_HoTen" },
      { from: "Dat_SDT", to: "Nhan_SDT" },
      { from: "Dat_CCCD", to: "Nhan_CCCD" }
    ];

    fields.forEach(f => {
      const fromInput = document.getElementById(f.from);
      const toInput = document.getElementById(f.to);
      toInput.value = this.checked ? fromInput.value : "";
      validateInput(toInput);
    });
  });

  /* ================= SUBMIT ================= */
  bookingForm.addEventListener("submit", function (e) {
    let valid = true;
    allInputs.forEach(input => {
      if (!validateInput(input)) valid = false;
    });

    if (!valid) {
      e.preventDefault();
      alert("❌ Vui lòng kiểm tra lại các trường thông tin màu đỏ!");
    }
  });
});
</script>