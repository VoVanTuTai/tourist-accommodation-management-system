<div class="container py-5">
    <div class="card shadow-lg border-0 mx-auto" style="max-width: 800px; border-radius: 20px;">
        <div class="card-header bg-white text-center py-4 border-0">
            <h3 class="fw-bold text-primary mb-0">Xác nhận thông tin đặt phòng</h3>
            <p class="text-muted small">Vui lòng kiểm tra kỹ thông tin trước khi nhấn xác nhận</p>
        </div>
        
        <div class="card-body px-5">
            <div class="alert alert-info border-0 rounded-4 p-4 mb-4">
                <div class="row align-items-center">
                    <div class="col-md-7">
                        <h5 class="fw-bold mb-1">Thông tin phòng</h5>
                        <p class="mb-0 small text-muted">
                            Lưu trú: <strong><%= don.NgayNhan %></strong> đến <strong><%= don.NgayTra %></strong>
                        </p>
                    </div>
                    <div class="col-md-5 text-md-end">
                        <span class="fs-4 fw-bold text-danger"><%= don.TongTien.toLocaleString() %> VND</span>
                        <div class="small text-muted">(Tổng cộng cho <%= don.SoDem %> đêm)</div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6 border-end">
                    <h6 class="text-uppercase fw-bold text-muted small mb-3">Người đặt phòng</h6>
                    <p class="mb-1 fw-bold"><%= don.Dat_HoTen %></p>
                    <p class="mb-1 small"><i class="fas fa-phone me-2"></i><%= don.Dat_SDT %></p>
                    <p class="mb-0 small"><i class="fas fa-id-card me-2"></i><%= don.Dat_CCCD %></p>
                </div>
                <div class="col-md-6 ps-md-4">
                    <h6 class="text-uppercase fw-bold text-muted small mb-3">Người nhận phòng</h6>
                    <p class="mb-1 fw-bold"><%= don.Nhan_HoTen %></p>
                    <p class="mb-1 small"><i class="fas fa-phone me-2"></i><%= don.Nhan_SDT %></p>
                    <p class="mb-0 small"><i class="fas fa-id-card me-2"></i><%= don.Nhan_CCCD %></p>
                </div>
            </div>

            <hr class="my-4">

            <div class="row g-3">
                <div class="col-md-6">
                    <a href="javascript:history.back()" class="btn btn-outline-secondary w-100 py-3 rounded-pill fw-bold">
                        <i class="fas fa-arrow-left me-2"></i>Quay lại sửa
                    </a>
                </div>
                <div class="col-md-6">
                    <form action="/khachhang/dat-phong/confirm" method="POST">
                        <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow">
                            HOÀN TẤT ĐẶT PHÒNG <i class="fas fa-check-circle ms-2"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f0f2f5; }
    .btn-primary { background: linear-gradient(90deg, #6c63ff, #4f46e5); border: none; transition: 0.3s; }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(108, 99, 255, 0.4); }
</style>