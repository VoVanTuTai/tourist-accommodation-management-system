
    
</head>
<body>
    <div class="container-fluid py-4">
        <div class="main-container">
            <div class="card-header text-white text-center">
                <h3 class="mb-0"><i class="fas fa-receipt me-2"></i>Chi tiết đơn đặt phòng</h3>
            </div>

            <div class="card-body p-4">
                <!-- Thông tin đơn -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="info-section">
                            <div class="info-label">Mã đơn</div>
                            <div class="info-value"><%= don.MaDon %></div>
                            
                            <div class="info-label">Khách hàng</div>
                            <div class="info-value"><%= don.TenKH %></div>
                            <div class="text-muted small">
                                <i class="fas fa-envelope me-1"></i><%= don.Email %> • 
                                <i class="fas fa-phone me-1"></i><%= don.SDT %>
                            </div>
                            
                            <div class="info-label mt-3">Ngày đặt</div>
                            <div class="info-value">
                                <i class="fas fa-calendar-plus me-2"></i>
                                <%= new Date(don.NgayDat).toLocaleDateString("vi-VN") %>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-section">
                            <div class="info-label">Ngày nhận phòng</div>
                            <div class="info-value">
                                <i class="fas fa-calendar-check me-2"></i>
                                <%= new Date(don.NgayNhan).toLocaleDateString("vi-VN") %>
                            </div>
                            
                            <div class="info-label">Ngày trả phòng</div>
                            <div class="info-value">
                                <i class="fas fa-calendar-times me-2"></i>
                                <%= new Date(don.NgayTra).toLocaleDateString("vi-VN") %>
                            </div>
                            
                            <div class="info-label">Tổng tiền</div>
                            <div class="price-highlight">
                                <i class="fas fa-money-bill-wave me-2"></i>
                                <%= (don.TongTien || 0).toLocaleString("vi-VN") %> ₫
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Trạng thái -->
                <div class="status-container">
                    <h5 class="mb-3"><i class="fas fa-info-circle me-2"></i>Trạng thái đơn hàng</h5>
                    <% if (don.TrangThai === 0) { %>
                        <span class="status-badge status-0">
                            <i class="fas fa-clock me-2"></i>Đã đặt
                        </span>
                    <% } else if (don.TrangThai === 1) { %>
                        <span class="status-badge status-1">
                            <i class="fas fa-bed me-2"></i>Đang sử dụng
                        </span>
                    <% } else if (don.TrangThai === 2) { %>
                        <span class="status-badge status-2">
                            <i class="fas fa-check-circle me-2"></i>Hoàn tất
                        </span>
                    <% } else if (don.TrangThai === 3) { %>
                        <span class="status-badge status-3">
                            <i class="fas fa-times-circle me-2"></i>Đã hủy
                        </span>
                    <% } %>
                </div>

                <hr class="divider">

                <!-- Thông tin phòng -->
                <div class="room-section">
                    <h5 class="section-title">
                        <i class="fas fa-hotel"></i>
                        Thông tin phòng
                    </h5>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="room-image">
                                    <% if (don.HinhAnh) { %>
                                      <img 
                                        src="/images/<%= don.HinhAnh %>" 
                                        alt="<%= don.TenPhong %>" 
                                        onerror="this.outerHTML='<div class=&quot;no-image&quot;><i class=&quot;fas fa-image fa-3x&quot;></i></div>'">
                                    <% } else { %>
                                      <div class="no-image"><i class="fas fa-image fa-3x"></i></div>
                                    <% } %>
                                
                                                             
                              </div>
                        </div>
                        <div class="col-md-8">
                            <div class="info-section">
                                <div class="info-label">Tên phòng</div>
                                <div class="info-value"><%= don.TenPhong || 'Chưa có thông tin' %></div>
                                
                                <div class="info-label">Loại phòng</div>
                                <div class="info-value"><%= don.LoaiPhong || 'Standard' %></div>
                                
                                <div class="info-label">Số đêm</div>
                                <div class="info-value">
                                    <% 
                                        const checkin = new Date(don.NgayNhan);
                                        const checkout = new Date(don.NgayTra);
                                        const nights = Math.ceil((checkout - checkin) / (1000 * 60 * 60 * 24));
                                    %>
                                    <%= nights %> đêm
                                </div>
                                
                                <div class="info-label">Giá phòng/đêm</div>
                                <div class="info-value">
                                    <% const pricePerNight = nights > 0 ? Math.round((don.TongTien || 0) / nights) : 0; %>
                                    <%= pricePerNight.toLocaleString("vi-VN") %> ₫
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Nút hành động -->
                <div class="action-buttons">
                    <button class="btn btn-primary" onclick="printBooking()">
                        <i class="fas fa-print me-2"></i>In hóa đơn
                    </button>
                    <button class="btn btn-secondary" onclick="goBack()">
                        <i class="fas fa-arrow-left me-2"></i>Quay lại
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function printBooking() {
            // Ẩn các nút khi in
            const buttons = document.querySelector('.action-buttons');
            const originalDisplay = buttons.style.display;
            buttons.style.display = 'none';
            
            // In trang
            window.print();
            
            // Hiện lại các nút sau khi in
            setTimeout(() => {
                buttons.style.display = originalDisplay;
            }, 1000);
        }

        function goBack() {
            // Mô phỏng quay lại trang trước
            if (window.history.length > 1) {
                window.history.back();
            } else {
                // Tạo thông báo inline thay vì alert
                const notification = document.createElement('div');
                notification.style.cssText = `
                    position: fixed;
                    top: 20px;
                    right: 20px;
                    background: #fee2e2;
                    color: #dc2626;
                    padding: 1rem 1.5rem;
                    border-radius: 8px;
                    border: 2px solid #ef4444;
                    z-index: 1000;
                    font-weight: 600;
                `;
                notification.innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i>Không có trang trước để quay lại';
                document.body.appendChild(notification);
                
                setTimeout(() => {
                    notification.remove();
                }, 3000);
            }
        }

        // Thêm hiệu ứng hover cho các thẻ thông tin
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.info-section').forEach(section => {
                section.addEventListener('mouseenter', function() {
                    this.style.transform = 'translateY(-2px)';
                    this.style.boxShadow = '0 8px 25px rgba(0,0,0,0.1)';
                    this.style.transition = 'all 0.3s ease';
                });
                
                section.addEventListener('mouseleave', function() {
                    this.style.transform = 'translateY(0)';
                    this.style.boxShadow = 'none';
                });
            });

            // Hiệu ứng cho status badge
            const statusBadge = document.querySelector('.status-badge');
            if (statusBadge) {
                statusBadge.addEventListener('click', function() {
                    this.style.transform = 'scale(1.05)';
                    setTimeout(() => {
                        this.style.transform = 'scale(1)';
                    }, 200);
                });
            }
        });
    </script>
