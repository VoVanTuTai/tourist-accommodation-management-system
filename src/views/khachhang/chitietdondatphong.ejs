<div class="container py-4 mt-3"
style="width: 95%; background-color: rgb(255, 255, 255);">
  <div class="main-container glass-card p-4">
    <!-- Header -->
    <div class="text-center mb-4">
      <h3 class="text-black mb-0">
        <i class="fas fa-receipt me-2"></i>Chi tiết đơn đặt phòng
      </h3>
    </div>

    <!-- Thông tin đơn -->
    <div class="row mb-4 text-black">
      <div class="col-md-6">
        <div class="info-section p-3 rounded-3 mb-3 shadow-sm bg-opacity-25 bg-white">
          <div><strong>Mã đơn:</strong> <%= don.MaDon %></div>
          <div><strong>Khách hàng đặt:</strong> <%= don.TenKhachHangDat %></div>

          <div class="small text-muted">
            <i class="fas fa-envelope me-1"></i><%= don.Email %> • 
            <i class="fas fa-phone me-1"></i><%= don.SDT %>
          </div>

          <div class="mt-3">
            <strong>Ngày đặt:</strong>
            <i class="fas fa-calendar-plus me-1"></i>
            <%= new Date(don.NgayDat).toLocaleDateString("vi-VN") %>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="info-section p-3 rounded-3 mb-3 shadow-sm bg-opacity-25 bg-white">
          <div>
            <strong>Ngày nhận phòng:</strong>
            <i class="fas fa-calendar-check me-1"></i>
            <%= new Date(don.NgayNhan).toLocaleDateString("vi-VN") %>
          </div>

          <div>
            <strong>Ngày trả phòng:</strong>
            <i class="fas fa-calendar-times me-1"></i>
            <%= new Date(don.NgayTra).toLocaleDateString("vi-VN") %>
          </div>

          <div class="price-highlight mt-3">
            <strong>Tổng tiền:</strong>
            <i class="fas fa-money-bill-wave me-1"></i>
            <%= (don.TongTien || 0).toLocaleString("vi-VN") %> ₫
          </div>
        </div>
      </div>
    </div>

    
<div class="status-container text-black mb-4">
  <h5 class="text-center mb-3">
    <i class="fas fa-info-circle me-2"></i>Trạng thái đơn & thanh toán
  </h5>

  <div class="row g-3">

    <!-- Trạng thái đơn -->
    <div class="col-md-6">
      <div class="info-section p-3 rounded-3 bg-opacity-25 bg-white shadow-sm text-center">

        <strong class="d-block mb-2">
          <i class="fas fa-file-alt me-1"></i>Trạng thái đơn
        </strong>

        <% if (don.TrangThai === 0) { %>
          <span class="badge bg-warning fs-6">
            <i class="fas fa-clock me-1"></i>Đã đặt
          </span>

        <% } else if (don.TrangThai === 1) { %>
          <span class="badge bg-primary fs-6">
            <i class="fas fa-bed me-1"></i>Đang sử dụng
          </span>

        <% } else if (don.TrangThai === 2) { %>
          <span class="badge bg-success fs-6">
            <i class="fas fa-check-circle me-1"></i>Hoàn tất
          </span>

        <% } else if (don.TrangThai === 3) { %>
          <span class="badge bg-danger fs-6">
            <i class="fas fa-times-circle me-1"></i>Đã hủy
          </span>
        <% } %>

      </div>
    </div>

    <!-- Trạng thái thanh toán -->
    <div class="col-md-6">
      <div class="info-section p-3 rounded-3 bg-opacity-25 bg-white shadow-sm text-center">

        <strong class="d-block mb-2">
          <i class="fas fa-wallet me-1"></i>Thanh toán
        </strong>

        <% if (don.TrangThaiThanhToan === 1) { %>
          <span class="badge bg-success fs-6">
            <i class="fas fa-check me-1"></i>Đã thanh toán
          </span>
        <% } else { %>
          <span class="badge bg-danger fs-6">
            <i class="fas fa-times me-1"></i>Chưa thanh toán
          </span>
        <% } %>

      </div>
    </div>

  </div>
</div>


    <hr class="text-black opacity-50">

    <!-- Thông tin người nhận -->
    <div class="recipient-section text-black mt-4">
      <h5 class="mb-3">
        <i class="fas fa-user-check me-2"></i>Thông tin người nhận phòng
      </h5>

      <div class="row">
        <div class="col-md-6">
          <div class="info-section p-3 bg-opacity-25 bg-white rounded-3 shadow-sm">
            <p><strong>Họ tên:</strong> <%= don.TenNguoiNhan || 'Chưa có thông tin' %></p>
          </div>
        </div>

        <div class="col-md-6">
          <div class="info-section p-3 bg-opacity-25 bg-white rounded-3 shadow-sm">
            <p><strong>Số điện thoại:</strong> <%= don.SDTNguoiNhan || 'Chưa có thông tin' %></p>
          </div>
        </div>
      </div>
    </div>

    <hr class="text-black opacity-50 mt-4">

    <!-- Thông tin phòng -->
    <div class="room-section text-black">
      <h5 class="mb-3"><i class="fas fa-hotel me-2"></i>Thông tin phòng</h5>

      <div class="row">
        <div class="col-md-4">
          <%
            let firstImage = null;
            try {
              const arr = JSON.parse(don.HinhAnh);   // parse chuỗi JSON
              if (Array.isArray(arr) && arr.length > 0) {
                firstImage = arr[0];                 // lấy ảnh đầu tiên
              }
            } catch (e) {
              firstImage = don.HinhAnh;              // fallback nếu HinhAnh chỉ là string
            }
          %>

          <% if (firstImage) { %>
            <img src="/images/<%= firstImage %>" 
                class="img-fluid rounded-3 shadow-sm"
                alt="Ảnh phòng"
                onerror="this.outerHTML='<div class=&quot;no-image&quot;><i class=&quot;fas fa-image fa-3x&quot;></i></div>'">
          <% } else { %>
            <div class="no-image bg-light p-4 rounded-3 text-center text-muted">
              <i class="fas fa-image fa-3x"></i>
              <div>Không có ảnh</div>
            </div>
          <% } %>

        </div>

        <div class="col-md-8">
          <div class="info-section p-3 bg-opacity-25 bg-white rounded-3 shadow-sm">
            <p><strong>Tên phòng:</strong> <%= don.TenPhong || 'Chưa có thông tin' %></p>
            <p><strong>Loại phòng:</strong> <%= don.LoaiPhong || 'Standard' %></p>

            <% 
              const checkin = new Date(don.NgayNhan);
              const checkout = new Date(don.NgayTra);
              const nights = Math.ceil((checkout - checkin) / (1000*60*60*24));
              const pricePerNight = nights > 0 ? Math.round((don.TongTien||0)/nights) : 0;
            %>

            <p><strong>Số đêm:</strong> <%= nights %> đêm</p>
            <p><strong>Giá/đêm:</strong> <%= pricePerNight.toLocaleString("vi-VN") %> ₫</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<div class="action-wrapper text-center mt-4">

  <% if (don.TrangThai === 0) { %>

    <div class="action-row">

      <!-- Nút HỦY ĐƠN (KHÔNG đặt trong form) -->
      <button type="button"
        class="action-btn btn-danger btn-open-cancel"
        data-ma-don="<%= don.MaDon %>">
          Hủy đơn
      </button>

      <% if (order) { %>
        <!-- Thanh toán VNPay -->
        <form action="/vnpay/create_payment" method="POST">
          <input type="hidden" name="amount" value="<%= order.TongTien %>">
          <input type="hidden" name="orderId" value="<%= order.MaDon %>">
          <input type="hidden" name="maNCC" value="<%= order.MaNCC %>">
          <button type="submit" class="action-btn btn-success">
            Thanh toán ngay bằng VNPay
          </button>
        </form>
      <% } %>

    </div>


  <% } else if (don.TrangThai === 1) { %>

    <div class="action-row">

      <% if (order) { %>
        <form action="/vnpay/create_payment" method="POST">
          <input type="hidden" name="amount" value="<%= order.TongTien %>">
          <input type="hidden" name="orderId" value="<%= order.MaDon %>">
          <input type="hidden" name="maNCC" value="<%= order.MaNCC %>">
          <button type="submit" class="action-btn btn-success">
            Thanh toán bằng VNPay
          </button>
        </form>
      <% } %>

    </div>

  <% } else if (don.TrangThai === 2) { %>

    <div class="action-row">

      <a href="/khachhang/don-dat-phong/<%= don.MaDon %>/danhgia"
        class="action-btn btn-warning">
        <i class="fas fa-star me-2"></i>Đánh giá
      </a>

      <button class="action-btn btn-primary" onclick="printBooking()">
        <i class="fas fa-print me-2"></i>In hóa đơn
      </button>

    </div>

  <% } %>

  <!-- Nút quay lại -->
  <div class="action-row mt-3">
    <button class="action-btn btn-secondary" onclick="goBack()">
      <i class="fas fa-arrow-left me-2"></i>Quay lại
    </button>
  </div>
  <!-- FORM ẨN ĐỂ GỬI LÝ DO HỦY -->
      <form id="cancelForm" action="/khachhang/don-dat-phong/huy/<%= don.MaDon %>" method="POST">
        <input type="hidden" name="LyDoHuy" id="LyDoHuy">
      </form>

      <!-- Modal Hủy Đơn -->
      <div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content glass-box">

            <div class="modal-header">
              <h5 class="modal-title">Hủy đặt phòng</h5>
            </div>

            <div class="modal-body">

              <label class="fw-bold">Chọn lý do hủy</label>
              <select id="reasonSelect" class="form-select">
                <option value="Thay đổi kế hoạch">Thay đổi kế hoạch</option>
                <option value="Giá không phù hợp">Giá không phù hợp</option>
                <option value="Tìm được nơi khác tốt hơn">Tìm được nơi khác tốt hơn</option>
                <option value="Không còn nhu cầu">Không còn nhu cầu</option>
                <option value="Lý do khác">Lý do khác</option>
              </select>

              <textarea id="reasonNote" class="form-control mt-3"
                        placeholder="Ghi chú thêm (không bắt buộc)"></textarea>

            </div>

            <div class="modal-footer">
              <button class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
              <button class="btn btn-danger" id="btnConfirmCancel">Xác nhận hủy</button>
            </div>

          </div>
        </div>
      </div>


</div>



<script>

// Mở modal khi bấm nút "Hủy đơn"
document.querySelector(".btn-open-cancel").addEventListener("click", function () {
  const modal = new bootstrap.Modal(document.getElementById("cancelModal"));
  modal.show();
});

// Xác nhận hủy
document.getElementById("btnConfirmCancel").addEventListener("click", () => {

  const reason = document.getElementById("reasonSelect").value;
  const note = document.getElementById("reasonNote").value.trim();

  // Gộp lý do + ghi chú (nếu có)
  const finalReason = note ? `${reason} - ${note}` : reason;

  // Gán vào input hidden gửi về controller
  document.getElementById("LyDoHuy").value = finalReason;

  // Submit form
  document.getElementById("cancelForm").submit();
});



function goBack() {
  if (window.history.length > 1) window.history.back();
  else window.location.href = "/khachhang/don-dat-phong";
}

function printBooking() {
  const btns = document.querySelector('.text-center.mt-4');
  btns.style.display = 'none';
  window.print();
  setTimeout(() => btns.style.display = 'block', 1000);
}
</script>

<style>

.glass-card {
  backdrop-filter: blur(12px);
  background: rgba(56, 74, 83, 0.15);
  border-radius: 16px;
  box-shadow: 0 8px 25px rgba(72, 138, 150, 0.2);
  
}

.info-section:hover {
  transform: translateY(-2px);
  transition: all 0.3s ease;
}

.price-highlight {
  font-size: 1.2rem;
  font-weight: 600;
  color: #facc15;
}
/* Wrapper căn giữa */
.action-wrapper {
    width: 100%;
}

/* Hàng nút ngang */
.action-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
}

/* Style chung cho nút */
.action-btn {
    padding: 12px 20px;
    border-radius: 25px;
    font-size: 0.95rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: 0.3s ease;
    min-width: 160px;
    justify-content: center;
}

/* Hover */
.action-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
}

/* Màu nút */
.btn-primary {
    background: linear-gradient(135deg, #6a8ddf, #8b7de8);
    color: white;
}

.btn-secondary {
    background: #6c7293;
    color: white;
}

.btn-danger {
    background: linear-gradient(135deg, #ff6b6b, #ee5a52);
    color: white;
}

.btn-warning {
    background: linear-gradient(135deg, #ffd93d, #ff9f43);
    color: #8b4513;
}

.btn-success {
    background: linear-gradient(135deg, #6bcf7f, #4ea5d9);
    color: white;
}

/* Responsive nhỏ */
@media (max-width: 576px) {
    .action-btn {
        width: 100%;
        min-width: unset;
        
    }
}

</style>
