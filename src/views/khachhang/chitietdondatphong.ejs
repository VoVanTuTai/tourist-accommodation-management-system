<div class="container-fluid py-4">
  <div class="main-container">
      <div class="card-header text-white text-center">
          <h3 class="mb-0"><i class="fas fa-receipt me-2"></i>Chi tiết đơn đặt phòng</h3>
      </div>

      <div class="card-body p-4">
          <!-- Thông tin đơn -->
          <div class="row mb-4">
              <div class="col-md-6">
                  <div class="info-section">
                      <div class="info-label">Mã đơn</div>
                      <div class="info-value"><%= don.MaDon %></div>
                      
                      <div class="info-label">Khách hàng</div>
                      <div class="info-value"><%= don.TenKH %></div>
                      <div class="text-muted small">
                          <i class="fas fa-envelope me-1"></i><%= don.Email %> • 
                          <i class="fas fa-phone me-1"></i><%= don.SDT %>
                      </div>
                      
                      <div class="info-label mt-3">Ngày đặt</div>
                      <div class="info-value">
                          <i class="fas fa-calendar-plus me-2"></i>
                          <%= new Date(don.NgayDat).toLocaleDateString("vi-VN") %>
                      </div>
                  </div>
              </div>
              <div class="col-md-6">
                  <div class="info-section">
                      <div class="info-label">Ngày nhận phòng</div>
                      <div class="info-value">
                          <i class="fas fa-calendar-check me-2"></i>
                          <%= new Date(don.NgayNhan).toLocaleDateString("vi-VN") %>
                      </div>
                      
                      <div class="info-label">Ngày trả phòng</div>
                      <div class="info-value">
                          <i class="fas fa-calendar-times me-2"></i>
                          <%= new Date(don.NgayTra).toLocaleDateString("vi-VN") %>
                      </div>
                      
                      <div class="info-label">Tổng tiền</div>
                      <div class="price-highlight">
                          <i class="fas fa-money-bill-wave me-2"></i>
                          <%= (don.TongTien || 0).toLocaleString("vi-VN") %> ₫
                      </div>
                  </div>
              </div>
          </div>

          <!-- Trạng thái -->
          <div class="status-container">
              <h5 class="mb-3"><i class="fas fa-info-circle me-2"></i>Trạng thái đơn hàng</h5>
              <% if (don.TrangThai === 0) { %>
                  <span class="status-badge status-0">
                      <i class="fas fa-clock me-2"></i>Đã đặt
                  </span>
              <% } else if (don.TrangThai === 1) { %>
                  <span class="status-badge status-1">
                      <i class="fas fa-bed me-2"></i>Đang sử dụng
                  </span>
              <% } else if (don.TrangThai === 2) { %>
                  <span class="status-badge status-2">
                      <i class="fas fa-check-circle me-2"></i>Hoàn tất
                  </span>
              <% } else if (don.TrangThai === 3) { %>
                  <span class="status-badge status-3">
                      <i class="fas fa-times-circle me-2"></i>Đã hủy
                  </span>
              <% } %>
          </div>

          <hr class="divider">

          <!-- Thông tin phòng -->
          <div class="room-section">
              <h5 class="section-title">
                  <i class="fas fa-hotel"></i>
                  Thông tin phòng
              </h5>
              <div class="row">
                  <div class="col-md-4">
                      <div class="room-image">
                          <% if (don.HinhAnh) { %>
                              <img src="/uploads/<%= don.HinhAnh %>" alt="<%= don.TenPhong %>">
                          <% } else { %>
                              <div class="no-image">
                                  <i class="fas fa-image fa-3x"></i>
                                  <div class="ms-3">Không có ảnh</div>
                              </div>
                          <% } %>
                      </div>
                  </div>
                  <div class="col-md-8">
                      <div class="info-section">
                          <div class="info-label">Tên phòng</div>
                          <div class="info-value">
                              <i class="fas fa-door-open me-2"></i>
                              <%= don.TenPhong %>
                          </div>
                          
                          <div class="info-label">Loại phòng</div>
                          <div class="info-value">
                              <i class="fas fa-tag me-2"></i>
                              <%= don.LoaiPhong || "Không rõ" %>
                          </div>
                          
                          <div class="info-label">Nhà cung cấp</div>
                          <div class="info-value">
                              <i class="fas fa-building me-2"></i>
                              <%= don.TenChoO %>
                          </div>
                          
                          <div class="info-label">Giá phòng</div>
                          <div class="info-value">
                              <span class="price-highlight">
                                  <%= (don.GiaPhong || 0).toLocaleString("vi-VN") %> ₫ / đêm
                              </span>
                          </div>
                      </div>
                  </div>
              </div>
          </div>

          <hr class="divider">

          <!-- Hành động -->
          <div class="action-buttons">
              <% if (don.TrangThai === 0) { %>
                  <!-- Đơn đã đặt → cho phép hủy -->
                  <form action="/khachhang/don-dat-phong/huy/<%= don.MaDon %>" method="POST" style="display:inline;">
                      <button class="btn btn-custom btn-danger-custom" onclick="return confirm('Bạn chắc chắn muốn hủy đơn này?')">
                          <i class="fas fa-times me-2"></i>Hủy đơn
                      </button>
                  </form>

              <% } else if (don.TrangThai === 1) { %>
                  <!-- Đơn đang sử dụng → cho phép thanh toán -->
                  <a href="/khachhang/don-dat-phong/thanhtoan/<%= don.MaDon %>" class="btn btn-custom btn-success-custom">
                      <i class="fas fa-credit-card me-2"></i>Thanh toán
                  </a>
                  
              <% } else if (don.TrangThai === 2) { %>
                  <!-- Đơn đã hoàn tất → cho phép đánh giá -->
                  <% if (don.daDanhGia) { %>
                      <div class="review-section">
                          <h6 class="fw-bold mb-3">
                              <i class="fas fa-star text-warning me-2"></i>
                              Đánh giá của bạn
                          </h6>
                          <p class="mb-3"><%= don.danhGia.NoiDung %></p>
                          <% if (don.danhGia.HinhAnh) { %>
                              <img src="/uploads/<%= don.danhGia.HinhAnh %>" class="img-thumbnail mt-2" style="max-width: 200px; border-radius: 10px;">
                          <% } %>
                          <div class="mt-3">
                              <a href="/khachhang/don-dat-phong/<%= don.MaDon %>/danhgia?edit=true" class="btn btn-custom btn-warning-custom">
                                  <i class="fas fa-edit me-2"></i>Chỉnh sửa đánh giá
                              </a>
                          </div>
                      </div>
                  <% } else { %>
                      <a href="/khachhang/don-dat-phong/<%= don.MaDon %>/danhgia" class="btn btn-custom btn-warning-custom">
                          <i class="fas fa-star me-2"></i>Đánh giá phòng
                      </a>
                  <% } %>
              <% } %>
          </div>
      </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
